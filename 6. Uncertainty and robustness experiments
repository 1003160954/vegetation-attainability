})

# ============================================================
# 1) Load data
# ============================================================
df0 = pd.read_parquet(DATA_FP)
print("✅ Loaded dataset from parquet:", df0.shape)
print("✅ Target:", target)

if DATE in df0.columns:
    df0[DATE] = pd.to_datetime(df0[DATE], errors="coerce")

if target not in df0.columns:
    raise ValueError(f"❌ target `{target}` not found in columns")

# available predictors by process group
group_vars = {}
for g, cols in PROCESS_GROUPS.items():
    avail = [c for c in cols if c in df0.columns]
    if len(avail) > 0:
        group_vars[g] = avail

all_predictors = []
for cols in group_vars.values():
    all_predictors.extend(cols)
all_predictors = list(dict.fromkeys(all_predictors))

if len(all_predictors) == 0:
    raise ValueError("❌ No usable predictors found in dataset.")

print("\n✅ Available process groups:")
for g, cols in group_vars.items():
    print(f"  - {g}: {cols}")

# ============================================================
# 2) Minimal clean
# ============================================================
need_cols = [CITY, target] + all_predictors
need_cols = [c for c in need_cols if c in df0.columns]

df = df0[need_cols].copy()

for c in [target] + all_predictors:
    df[c] = pd.to_numeric(df[c], errors="coerce")

df = df.dropna(subset=[CITY, target]).copy()

min_nonnull_predictors = max(3, int(0.6 * len(all_predictors)))
nonnull_count = df[all_predictors].notna().sum(axis=1)
df = df[nonnull_count >= min_nonnull_predictors].copy()

df[CITY] = df[CITY].astype("category")

print("\nAfter basic cleaning:", df.shape)
print("Cities:", df[CITY].nunique())

# ============================================================
# 3) Balanced sampling
# ============================================================
parts = []
rng = np.random.default_rng(RANDOM_STATE)

for city, g in df.groupby(CITY, observed=True):
    if len(g) > MAX_ROWS_PER_CITY:
        idx = rng.choice(g.index.to_numpy(), size=MAX_ROWS_PER_CITY, replace=False)
        parts.append(df.loc[idx])
    else:
        parts.append(g)

df_s = pd.concat(parts, axis=0).reset_index(drop=True)

if len(df_s) > MAX_TOTAL_ROWS:
    df_s = df_s.sample(MAX_TOTAL_ROWS, random_state=RANDOM_STATE).reset_index(drop=True)

print("After balanced sampling:", df_s.shape)

fill_values = {}
for c in all_predictors:
    fill_values[c] = float(df_s[c].median()) if df_s[c].notna().any() else 0.0

for c in all_predictors:
    df_s[c] = df_s[c].fillna(fill_values[c])

# ============================================================
# 4) Correlation matrix
# ============================================================
corr_vars = [c for c in CORE_COLLINEARITY_VARS if c in df_s.columns]
corr_df = df_s[corr_vars].corr(method="spearman")
corr_df.to_csv(os.path.join(OUT_DIR, "correlation_matrix_spearman.csv"))

