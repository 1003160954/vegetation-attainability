    dfn = valid_df.copy()
    if len(dfn) > NAIVE_SAMPLE_MAX:
        dfn = dfn.sample(NAIVE_SAMPLE_MAX, random_state=RANDOM_STATE).reset_index(drop=True)
    else:
        dfn = dfn.reset_index(drop=True)

    dfn["Year"] = dfn[DATE].dt.year.astype(int)
    dfn["Month"] = dfn[DATE].dt.month.astype(int)

    bg_fill_values = {}
    for c in NN_BACKGROUND_VARS:
        med = dfn[c].median()
        if not np.isfinite(med):
            med = 0.0
        bg_fill_values[c] = float(med)
        dfn[c] = pd.to_numeric(dfn[c], errors="coerce").fillna(bg_fill_values[c])

    # --------------------------------------------------------
    # C1. Same-city same-month low-EVI median subtraction
    # --------------------------------------------------------
    ref_pool = dfn[dfn["EVI"] <= LOW_EVI_REF].copy()

    simple_ref = (
        ref_pool.groupby([CITY, "Month"], observed=True)
        .agg(
            ref_lst_median=(TARGET_LST, "median"),
            ref_evi_median=("EVI", "median"),
            ref_n=("EVI", "size")
        )
        .reset_index()
    )

    simple = dfn.merge(simple_ref, on=[CITY, "Month"], how="left")
    simple["naive1_deltaLST"] = simple["ref_lst_median"] - simple[TARGET_LST]
    simple["naive1_dEVI"] = simple["EVI"] - simple["ref_evi_median"]
    simple["naive1_CE"] = np.where(
        simple["naive1_dEVI"] >= MIN_DEVI,
        simple["naive1_deltaLST"] / np.maximum(simple["naive1_dEVI"], 1e-6),
        np.nan
    )

    simple_bg_ref = (
        ref_pool.groupby([CITY, "Month"], observed=True)[NN_BACKGROUND_VARS]
        .median()
        .reset_index()
    )
    simple = simple.merge(simple_bg_ref, on=[CITY, "Month"], how="left", suffixes=("", "_refbg"))

    dist_terms = []
    for c in NN_BACKGROUND_VARS:
        sd = float(dfn[c].std())
        if (not np.isfinite(sd)) or (sd <= 0):
            sd = 1.0
        ref_col = f"{c}_refbg"
        simple[ref_col] = pd.to_numeric(simple[ref_col], errors="coerce").fillna(bg_fill_values[c])
        dist_terms.append(((simple[c] - simple[ref_col]) / sd) ** 2)
    simple["naive1_bg_mismatch"] = np.sqrt(np.sum(dist_terms, axis=0))

    # --------------------------------------------------------
    # C2. nearest low-EVI analog, chunked to disk
    # --------------------------------------------------------
    # clear old chunks
    for fn in os.listdir(C_TMP_CHUNK_DIR):
        if fn.endswith(".parquet"):
            os.remove(os.path.join(C_TMP_CHUNK_DIR, fn))

    chunk_id = 0
    buffer_rows = []

    for (city, month), gq in dfn.groupby([CITY, "Month"], observed=True):
        gr = ref_pool[(ref_pool[CITY] == city) & (ref_pool["Month"] == month)].copy()

        if len(gr) < 8 or len(gq) < 8:
            continue

        Xr = gr[NN_BACKGROUND_VARS].copy()
        Xq = gq[NN_BACKGROUND_VARS].copy()

        for c in NN_BACKGROUND_VARS:
            Xr[c] = pd.to_numeric(Xr[c], errors="coerce").fillna(bg_fill_values[c])
            Xq[c] = pd.to_numeric(Xq[c], errors="coerce").fillna(bg_fill_values[c])

        mu = Xr.mean(axis=0).replace([np.inf, -np.inf], 0.0).fillna(0.0)
        sd = Xr.std(axis=0).replace(0, 1.0).replace([np.inf, -np.inf], 1.0).fillna(1.0)

        Xr_std = ((Xr - mu) / sd).replace([np.inf, -np.inf], np.nan).fillna(0.0)
        Xq_std = ((Xq - mu) / sd).replace([np.inf, -np.inf], np.nan).fillna(0.0)

        try:
            nbrs = NearestNeighbors(n_neighbors=N_NEIGHBORS, algorithm="auto")
            nbrs.fit(Xr_std.to_numpy(dtype=float))
            dist, idx = nbrs.kneighbors(Xq_std.to_numpy(dtype=float))
        except Exception:
            del Xr, Xq, Xr_std, Xq_std
            gc.collect()
            continue

        match = gr.iloc[idx[:, 0]].reset_index(drop=True)
        qq = gq.reset_index(drop=True)

        tmp = qq[[CITY, DATE, "EVI", TARGET_LST] + NN_BACKGROUND_VARS].copy()
        tmp["ref_LST"] = match[TARGET_LST].to_numpy()
        tmp["ref_EVI"] = match["EVI"].to_numpy()
        tmp["bg_distance"] = dist[:, 0]
        tmp["naive2_deltaLST"] = tmp["ref_LST"] - tmp[TARGET_LST]
        tmp["naive2_dEVI"] = tmp["EVI"] - tmp["ref_EVI"]
        tmp["naive2_CE"] = np.where(
            tmp["naive2_dEVI"] >= MIN_DEVI,
            tmp["naive2_deltaLST"] / np.maximum(tmp["naive2_dEVI"], 1e-6),
            np.nan
        )

        buffer_rows.append(tmp)

        if len(buffer_rows) >= 15:
            chunk = pd.concat(buffer_rows, axis=0, ignore_index=True)
            chunk_fp = os.path.join(C_TMP_CHUNK_DIR, f"naive2_chunk_{chunk_id:03d}.parquet")
            chunk.to_parquet(chunk_fp, index=False)
            chunk_id += 1
            buffer_rows = []
            del chunk
            gc.collect()

        del Xr, Xq, Xr_std, Xq_std, match, qq, tmp
        gc.collect()

    if len(buffer_rows) > 0:
        chunk = pd.concat(buffer_rows, axis=0, ignore_index=True)
        chunk_fp = os.path.join(C_TMP_CHUNK_DIR, f"naive2_chunk_{chunk_id:03d}.parquet")
        chunk.to_parquet(chunk_fp, index=False)
        del chunk
        buffer_rows = []
        gc.collect()

    # combine chunks
    chunk_files = sorted([os.path.join(C_TMP_CHUNK_DIR, f) for f in os.listdir(C_TMP_CHUNK_DIR) if f.endswith(".parquet")])
    if len(chunk_files) > 0:
        naive2 = pd.concat([pd.read_parquet(fp) for fp in chunk_files], axis=0, ignore_index=True)
    else:
        naive2 = pd.DataFrame()

    # --------------------------------------------------------
    # ML reference
    # --------------------------------------------------------
    ml_ref = pd.read_parquet(B_HISTGB_FULL_OUT_FP)
    ml_ref = ml_ref.merge(dfn[[CITY, DATE]], on=[CITY, DATE], how="inner")
    ml_ref = ml_ref.rename(columns={
        "cooling_strength_pred": "ml_deltaLST",
        "cooling_efficiency": "ml_CE"
    })

    cmp = dfn[[CITY, DATE, "EVI", TARGET_LST] + NN_BACKGROUND_VARS].copy()
    cmp = cmp.merge(ml_ref[[CITY, DATE, "ml_deltaLST", "ml_CE"]], on=[CITY, DATE], how="left")
    cmp = cmp.merge(
        simple[[CITY, DATE, "naive1_deltaLST", "naive1_CE", "naive1_bg_mismatch", "naive1_dEVI", "ref_n"]],
        on=[CITY, DATE], how="left"
    )

    if len(naive2) > 0:
        cmp = cmp.merge(
            naive2[[CITY, DATE, "naive2_deltaLST", "naive2_CE", "bg_distance", "naive2_dEVI"]],
            on=[CITY, DATE], how="left"
        )

    def summarize_method(df_cmp, delta_col, ce_col, extra=None):
        valid = np.isfinite(df_cmp[delta_col])
        ce_valid = np.isfinite(df_cmp[ce_col])

        out = {
            "method": delta_col.replace("_deltaLST", ""),
            "coverage_delta": float(valid.mean()),
            "coverage_ce": float(ce_valid.mean()),
            "delta_median": float(np.nanmedian(df_cmp[delta_col])) if valid.sum() > 0 else np.nan,
            "delta_p95": float(np.nanquantile(df_cmp[delta_col].dropna(), 0.95)) if valid.sum() > 20 else np.nan,
            "ce_median": float(np.nanmedian(df_cmp[ce_col])) if ce_valid.sum() > 0 else np.nan,
            "ce_iqr": float(np.nanquantile(df_cmp[ce_col].dropna(), 0.75) - np.nanquantile(df_cmp[ce_col].dropna(), 0.25)) if ce_valid.sum() > 20 else np.nan,
