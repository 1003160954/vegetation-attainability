        rank_ratio_df[["baseline", "ratio_spearman_rankcorr", "ratio_pearson_corr"]],
        on="baseline", how="left"
    )
else:
    score_df["ratio_spearman_rankcorr"] = np.nan
    score_df["ratio_pearson_corr"] = np.nan

if len(overlap_contrast_df) > 0:
    score_df = score_df.merge(
        overlap_contrast_df[["baseline", "contrast_bottom10_overlap", "contrast_top10_overlap"]],
        on="baseline", how="left"
    )
else:
    score_df["contrast_bottom10_overlap"] = np.nan
    score_df["contrast_top10_overlap"] = np.nan

if len(overlap_ratio_df) > 0:
    score_df = score_df.merge(
        overlap_ratio_df[["baseline", "ratio_bottom10_overlap", "ratio_top10_overlap"]],
        on="baseline", how="left"
    )
else:
    score_df["ratio_bottom10_overlap"] = np.nan
    score_df["ratio_top10_overlap"] = np.nan

score_df["baseline_numeric"] = score_df["baseline"].str.replace("FIXED_", "", regex=False).astype(float)

# realism / practical interpretability:
# prefer low reference values, but not at the cost of instability
score_df["score_near_zero"] = minmax_scale(score_df["baseline_numeric"], reverse=True)

# validity / stability / rank
score_df["score_valid"] = minmax_scale(score_df["valid_frac"], reverse=False)
score_df["score_iqr"] = minmax_scale(score_df["ratio_iqr"], reverse=True)
score_df["score_contrast_rank"] = minmax_scale(score_df["contrast_spearman_rankcorr"].fillna(score_df["contrast_spearman_rankcorr"].median()), reverse=False)
score_df["score_ratio_rank"] = minmax_scale(score_df["ratio_spearman_rankcorr"].fillna(score_df["ratio_spearman_rankcorr"].median()), reverse=False)

# overlaps
score_df["score_contrast_overlap"] = (
    score_df[["contrast_bottom10_overlap", "contrast_top10_overlap"]]
    .mean(axis=1)
)
score_df["score_ratio_overlap"] = (
    score_df[["ratio_bottom10_overlap", "ratio_top10_overlap"]]
    .mean(axis=1)
)

# practical magnitude: avoid overly tiny contrast median or absurdly large ratio
score_df["score_contrast_median"] = minmax_scale(score_df["contrast_median"], reverse=False)

# final score: emphasize stability and structural robustness more than "close to zero"
score_df["overall_score"] = (
    0.22 * score_df["score_valid"] +
    0.20 * score_df["score_iqr"] +
    0.16 * score_df["score_contrast_rank"] +
    0.16 * score_df["score_ratio_rank"] +
    0.10 * score_df["score_contrast_overlap"] +
    0.10 * score_df["score_ratio_overlap"] +
    0.04 * score_df["score_contrast_median"] +
    0.02 * score_df["score_near_zero"]
)

score_df = score_df.sort_values("overall_score", ascending=False).reset_index(drop=True)
