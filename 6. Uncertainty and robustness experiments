def predict_model_fast(model, X_df):
    X_use = X_df.copy()
    for c in X_use.columns:
        if X_use[c].isna().any():
            X_use[c] = X_use[c].fillna(X_use[c].median())
    return model.predict(X_use.to_numpy(dtype=np.float32)).astype(np.float32)

def safe_corr(x, y, method="spearman"):
    sx = pd.Series(x)
    sy = pd.Series(y)
    tmp = pd.concat([sx, sy], axis=1).dropna()
    if len(tmp) < 10:
        return np.nan
    return float(tmp.iloc[:, 0].corr(tmp.iloc[:, 1], method=method))

def minmax_scale(x, reverse=False):
    x = np.asarray(x, dtype=float)
    mn = np.nanmin(x)
    mx = np.nanmax(x)
    if np.isclose(mx, mn):
        out = np.full_like(x, 0.5)
    else:
        out = (x - mn) / (mx - mn)
    if reverse:
        out = 1 - out
    return out

