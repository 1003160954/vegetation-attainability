# -*- coding: utf-8 -*-
# ============================================================
# Mechanism-gating / physical-process consistency experiment
#
# Goal:
#   Test whether vegetation cooling efficiency is governed by
#   physically interpretable process gates:
#     vegetation capacity × atmospheric demand × energy supply × water supply
#
# Data:
#   EVI=0.05 counterfactual version
#
# Outputs:
#   1) gating_summary_tables
#   2) VPD × SSRD heatmaps under different water states
#   3) EVI / LAI gating curves under different physical backgrounds
#   4) concise summary tables for writing
# ============================================================

import os
import gc
import json
import math
import warnings
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

warnings.filterwarnings("ignore")

# ============================================================
# 0) Config
# ============================================================
DATA_FP = "/content/drive/MyDrive/Second_research/derived_datasets/GlobalUrbanCooling_dataset_v3_EVI005_with_lat.parquet"
OUT_DIR = "/content/drive/MyDrive/Second_research/MERRA/mechanism_gating_EVI005"
os.makedirs(OUT_DIR, exist_ok=True)

CITY = "city"
DATE = "date"
YEAR = "Year"
MONTH = "Month"

CE = "cooling_efficiency"
CS = "cooling_strength_pred"

# core physical variables
EVI = "EVI"
LAI = "LAI"
VPD = "VPD_kPa"
SSRD = "SSRD_MJm2"
SWVL1 = "SWVL1_m3m3"
TP = "TP_mm"
T2M = "T2M_C"
TD = "TD_C"
WIND = "WIND10M_MS"

# baseline summer definition
BASELINE_YEARS = (2002, 2006)
HOTTEST_K = 3

# active cooling definition
# use city-specific summer baseline CE quantile
ACTIVE_Q = 0.60

# bin settings
Q_DEMAND = 3     # VPD terciles
Q_ENERGY = 3     # SSRD terciles
Q_WATER  = 2     # SWVL1 median split (low/high)
Q_EVI    = 6
Q_LAI    = 6

# speed controls
MAX_ROWS_PER_CITY = 120000
MAX_TOTAL_ROWS = 1200000
RANDOM_STATE = 42

# minimum denominator threshold for stable CE
MIN_DEVI = 0.02

# plot style
plt.rcParams.update({
    "font.family": "DejaVu Sans",
    "font.size": 10.5,
    "axes.titlesize": 11.5,
    "axes.labelsize": 10.5,
    "xtick.labelsize": 9.3,
    "ytick.labelsize": 9.3,
    "legend.fontsize": 8.5,
    "axes.linewidth": 0.8,
    "figure.dpi": 140,
    "savefig.dpi": 320,
    "svg.fonttype": "none",
})

# ============================================================
# 1) Load data
# ============================================================
df0 = pd.read_parquet(DATA_FP)
print("Loaded:", df0.shape)

required = [CITY, DATE, YEAR, MONTH, EVI, LAI, VPD, SSRD, SWVL1, TP, T2M, TD, WIND, CS, CE, "dEVI_ref"]
missing = [c for c in required if c not in df0.columns]
if missing:
    raise ValueError(f"❌ Missing columns: {missing}")

df0[DATE] = pd.to_datetime(df0[DATE], errors="coerce")

# keep only needed columns
df = df0[required].copy()

# numeric coercion
num_cols = [c for c in required if c not in [CITY, DATE]]
for c in num_cols:
    df[c] = pd.to_numeric(df[c], errors="coerce")

df = df.dropna(subset=[CITY, DATE, YEAR, MONTH, EVI, VPD, SSRD, SWVL1, CS, "dEVI_ref"]).copy()

# stable CE subset
df = df[df["dEVI_ref"] >= MIN_DEVI].copy()

print("After stable-CE filter:", df.shape)
print("Cities:", df[CITY].nunique())

# ============================================================
# 2) Balanced sampling
# ============================================================
rng = np.random.default_rng(RANDOM_STATE)
parts = []
for city, g in df.groupby(CITY, observed=True):
    if len(g) > MAX_ROWS_PER_CITY:
        idx = rng.choice(g.index.to_numpy(), size=MAX_ROWS_PER_CITY, replace=False)
        parts.append(df.loc[idx])
    else:
        parts.append(g)

df = pd.concat(parts, axis=0).reset_index(drop=True)

if len(df) > MAX_TOTAL_ROWS:
    df = df.sample(MAX_TOTAL_ROWS, random_state=RANDOM_STATE).reset_index(drop=True)

df[CITY] = df[CITY].astype("category")
print("After balanced sampling:", df.shape)

# ============================================================
# 3) Define city-specific summer months
# ============================================================
b0, b1 = BASELINE_YEARS
base = df[(df[YEAR] >= b0) & (df[YEAR] <= b1)].copy()
if base.empty:
    raise RuntimeError("❌ Baseline years not found in data")

m = (
    base.groupby([CITY, MONTH], observed=True)[T2M]
    .mean()
    .reset_index()
    .sort_values([CITY, T2M], ascending=[True, False])
)
m["rank"] = m.groupby(CITY, observed=True).cumcount() + 1
hot_months = (
    m[m["rank"] <= HOTTEST_K]
    .groupby(CITY, observed=True)[MONTH]
    .apply(lambda x: sorted(list(set(x.astype(int).tolist()))))
    .to_dict()
)

city_arr = df[CITY].astype(str).to_numpy()
month_arr = df[MONTH].to_numpy()

is_summer = np.zeros(len(df), dtype=bool)
for city, mons in hot_months.items():
    mask = (city_arr == str(city))
    if mask.any():
        is_summer[mask] = np.isin(month_arr[mask], mons)

df = df[is_summer].copy().reset_index(drop=True)
print("Summer subset:", df.shape)

# ============================================================
# 4) Define active cooling
#    city-specific summer baseline CE quantile
# ============================================================
base_summer = df[(df[YEAR] >= b0) & (df[YEAR] <= b1)].copy()
city_thr = (
    base_summer.groupby(CITY, observed=True)[CE]
    .quantile(ACTIVE_Q)
    .rename("ce_thr_city")
    .reset_index()
)

df = df.merge(city_thr, on=CITY, how="left")
df["active_cooling"] = (df[CE] > df["ce_thr_city"]).astype(np.int8)

# ============================================================
# 5) Build physical-state bins
# ============================================================
# global summer bins (simple, robust)
df["VPD_bin"] = pd.qcut(df[VPD], q=Q_DEMAND, labels=[f"V{i+1}" for i in range(Q_DEMAND)], duplicates="drop")
df["SSRD_bin"] = pd.qcut(df[SSRD], q=Q_ENERGY, labels=[f"S{i+1}" for i in range(Q_ENERGY)], duplicates="drop")
df["SWVL1_bin"] = pd.qcut(df[SWVL1], q=Q_WATER, labels=[f"W{i+1}" for i in range(Q_WATER)], duplicates="drop")

# EVI / LAI bins for gating curves
df["EVI_bin"] = pd.qcut(df[EVI], q=Q_EVI, labels=[f"E{i+1}" for i in range(Q_EVI)], duplicates="drop")
if df[LAI].notna().sum() > 0:
    df["LAI_bin"] = pd.qcut(df[LAI], q=Q_LAI, labels=[f"L{i+1}" for i in range(Q_LAI)], duplicates="drop")
else:
    df["LAI_bin"] = np.nan

# keep only rows with valid bins
df = df.dropna(subset=["VPD_bin", "SSRD_bin", "SWVL1_bin", "EVI_bin"]).copy()
print("After binning:", df.shape)

# ============================================================
# 6) City-median gating table
#    use city medians first -> then global medians across cities
# ============================================================
# row-level -> city × state aggregation
city_state = (
    df.groupby([CITY, "VPD_bin", "SSRD_bin", "SWVL1_bin"], observed=True)
    .agg(
        ce_median=(CE, "median"),
        ce_mean=(CE, "mean"),
        cs_median=(CS, "median"),
        p_active=("active_cooling", "mean"),
        n=("active_cooling", "size")
    )
    .reset_index()
)

city_state.to_csv(os.path.join(OUT_DIR, "city_state_summary.csv"), index=False)

# global median across cities
global_state = (
    city_state.groupby(["VPD_bin", "SSRD_bin", "SWVL1_bin"], observed=True)
    .agg(
        city_n=(CITY, "nunique"),
        ce_median_citymedian=("ce_median", "median"),
        cs_median_citymedian=("cs_median", "median"),
        p_active_citymedian=("p_active", "median")
    )
    .reset_index()
)

global_state.to_csv(os.path.join(OUT_DIR, "global_state_summary.csv"), index=False)

# ============================================================
# 7) Hotspot tables: strongest activation / strongest CE
# ============================================================
top_active = global_state.sort_values("p_active_citymedian", ascending=False).reset_index(drop=True)
top_ce = global_state.sort_values("ce_median_citymedian", ascending=False).reset_index(drop=True)

top_active.to_csv(os.path.join(OUT_DIR, "top_active_windows.csv"), index=False)
top_ce.to_csv(os.path.join(OUT_DIR, "top_ce_windows.csv"), index=False)

# ============================================================
# 8) Heatmaps: VPD × SSRD under low/high water
# ============================================================
def make_heatmap_table(df_state, water_label, value_col):
    sub = df_state[df_state["SWVL1_bin"].astype(str) == water_label].copy()
    if sub.empty:
        return None
    mat = sub.pivot_table(index="SSRD_bin", columns="VPD_bin", values=value_col, aggfunc="median")
    return mat

def draw_heatmap(ax, mat, title, cbar_label, cmap="viridis"):
    if mat is None or mat.empty:
        ax.axis("off")
        ax.set_title(title + "\n(no data)")
        return None

    arr = mat.to_numpy(dtype=float)
    im = ax.imshow(arr, origin="lower", aspect="auto", cmap=cmap)

    ax.set_xticks(range(mat.shape[1]))
    ax.set_xticklabels(mat.columns.astype(str).tolist())
    ax.set_yticks(range(mat.shape[0]))
    ax.set_yticklabels(mat.index.astype(str).tolist())
    ax.set_xlabel("Atmospheric demand (VPD tercile)")
    ax.set_ylabel("Energy supply (SSRD tercile)")
    ax.set_title(title)

    for i in range(mat.shape[0]):
        for j in range(mat.shape[1]):
            v = arr[i, j]
            if np.isfinite(v):
                ax.text(j, i, f"{v:.2f}", ha="center", va="center",
                        color="white" if v > np.nanmedian(arr) else "black", fontsize=8)
    return im

for metric, cmap, fname in [
    ("p_active_citymedian", "viridis", "Fig_gate_heatmap_active.png"),
    ("ce_median_citymedian", "coolwarm", "Fig_gate_heatmap_ce.png"),
]:
    fig, axes = plt.subplots(1, 2, figsize=(10.8, 4.7), constrained_layout=True)

    mat_low = make_heatmap_table(global_state, "W1", metric)
    mat_high = make_heatmap_table(global_state, "W2", metric)

    im1 = draw_heatmap(
        axes[0], mat_low,
        f"Low water availability ({metric})",
        metric, cmap=cmap
    )
    im2 = draw_heatmap(
        axes[1], mat_high,
        f"High water availability ({metric})",
        metric, cmap=cmap
    )

    if im2 is not None:
        cbar = fig.colorbar(im2, ax=axes.ravel().tolist(), shrink=0.92)
        cbar.set_label(metric)

    plt.savefig(os.path.join(OUT_DIR, fname), bbox_inches="tight")
    plt.savefig(os.path.join(OUT_DIR, fname.replace(".png", ".svg")), bbox_inches="tight")
    plt.close(fig)

# ============================================================
# 9) Gating curves: EVI -> CE under different backgrounds
# ============================================================
# define a few interpretable windows
#   low demand + low energy
#   mid demand + mid energy
#   high demand + high energy
WINDOWS = [
    ("V1", "S1", "W1", "Low demand · low energy · low water"),
    ("V2", "S2", "W2", "Moderate demand · moderate energy · high water"),
    ("V3", "S3", "W2", "High demand · high energy · high water"),
    ("V3", "S3", "W1", "High demand · high energy · low water"),
]

curve_rows = []
for v_bin, s_bin, w_bin, label in WINDOWS:
    subw = df[
        (df["VPD_bin"].astype(str) == v_bin) &
        (df["SSRD_bin"].astype(str) == s_bin) &
        (df["SWVL1_bin"].astype(str) == w_bin)
    ].copy()
    if len(subw) < 300:
        continue

    # city x EVI_bin medians first
    tmp = (
        subw.groupby([CITY, "EVI_bin"], observed=True)
        .agg(
            evi_median=(EVI, "median"),
            ce_median=(CE, "median"),
            cs_median=(CS, "median"),
            p_active=("active_cooling", "mean"),
            n=("active_cooling", "size")
        )
        .reset_index()
    )
    tmp["window_label"] = label
    curve_rows.append(tmp)

curve_evi = pd.concat(curve_rows, axis=0, ignore_index=True) if len(curve_rows) > 0 else pd.DataFrame()
curve_evi.to_csv(os.path.join(OUT_DIR, "curve_evi_citybin.csv"), index=False)

if len(curve_evi) > 0:
    curve_evi_global = (
        curve_evi.groupby(["window_label", "EVI_bin"], observed=True)
        .agg(
            city_n=(CITY, "nunique"),
            evi_median=("evi_median", "median"),
            ce_median=("ce_median", "median"),
