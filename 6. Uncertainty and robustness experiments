# ============================================================
# 5) Experiment A: denominator-bin instability
# ============================================================
print("\nRunning denominator-bin instability experiment ...")

# only positive denominator for CE used in your main analysis
den = df["dEVI_ref"].to_numpy(dtype=np.float32)
m_pos = den > 0
work = df.loc[m_pos, [CITY, YEAR, EVI_COL, "dEVI_ref", "cooling_strength_pred", "cooling_efficiency_raw"]].copy()

work["dEVI_bin"] = pd.cut(work["dEVI_ref"], bins=BIN_EDGES, include_lowest=True)

bin_rows = []
for b, g in work.groupby("dEVI_bin", observed=True):
    if len(g) == 0:
        continue

    cs = g["cooling_strength_pred"].to_numpy(dtype=np.float32)
    ce = g["cooling_efficiency_raw"].to_numpy(dtype=np.float32)

    ce_valid = ce[np.isfinite(ce)]
    cs_valid = cs[np.isfinite(cs)]

    if len(ce_valid) == 0:
        continue

    q05 = float(np.nanquantile(ce_valid, 0.05))
    q25 = float(np.nanquantile(ce_valid, 0.25))
    q50 = float(np.nanquantile(ce_valid, 0.50))
    q75 = float(np.nanquantile(ce_valid, 0.75))
    q95 = float(np.nanquantile(ce_valid, 0.95))

    mad = float(np.nanmedian(np.abs(ce_valid - q50)))
    tail_width = q95 - q05
    iqr = q75 - q25

    bin_rows.append({
        "dEVI_bin": str(b),
        "dEVI_min": float(g["dEVI_ref"].min()),
        "dEVI_median": float(g["dEVI_ref"].median()),
        "dEVI_max": float(g["dEVI_ref"].max()),
        "n": int(len(g)),
        "cs_mean": float(np.nanmean(cs_valid)),
        "cs_median": float(np.nanmedian(cs_valid)),
        "cs_iqr": float(np.nanquantile(cs_valid, 0.75) - np.nanquantile(cs_valid, 0.25)),
        "ce_mean": float(np.nanmean(ce_valid)),
        "ce_median": q50,
        "ce_iqr": iqr,
        "ce_mad": mad,
        "ce_p05": q05,
        "ce_p95": q95,
        "ce_tail_width": tail_width
    })

bin_df = pd.DataFrame(bin_rows).sort_values("dEVI_median").reset_index(drop=True)
bin_df.to_csv(os.path.join(OUT_DIR, "denominator_bin_summary.csv"), index=False)

# ============================================================
# 6) Experiment B: threshold sweep stability
# ============================================================
print("\nRunning threshold sweep stability experiment ...")

thr_rows = []
city_tables = {}

for thr in THRESH_GRID:
    m = df["dEVI_ref"].to_numpy(dtype=np.float32) >= np.float32(thr)
    g = df.loc[m, [CITY, YEAR, "dEVI_ref", "cooling_strength_pred"]].copy()

    if len(g) < 100:
        continue

    g["cooling_efficiency"] = (
        g["cooling_strength_pred"].to_numpy(dtype=np.float32)
        / g["dEVI_ref"].to_numpy(dtype=np.float32)
    ).astype(np.float32)

    ce_valid = g["cooling_efficiency"].to_numpy(dtype=np.float32)
    cs_valid = g["cooling_strength_pred"].to_numpy(dtype=np.float32)

    # overall metrics
    q05 = float(np.nanquantile(ce_valid, 0.05))
    q25 = float(np.nanquantile(ce_valid, 0.25))
    q50 = float(np.nanquantile(ce_valid, 0.50))
    q75 = float(np.nanquantile(ce_valid, 0.75))
    q95 = float(np.nanquantile(ce_valid, 0.95))

    iqr = q75 - q25
    mad = float(np.nanmedian(np.abs(ce_valid - q50)))
    tail_width = q95 - q05

    # city-level table for ranking stability
    city_tab = (
        g.groupby(CITY, observed=True)
        .agg(
            n=("cooling_efficiency", "size"),
            city_ce_mean=("cooling_efficiency", "mean"),
            city_ce_median=("cooling_efficiency", "median"),
            city_cs_mean=("cooling_strength_pred", "mean"),
            city_cs_median=("cooling_strength_pred", "median")
        )
        .reset_index()
    )
    city_tab["threshold"] = thr
    city_tables[thr] = city_tab

    thr_rows.append({
        "threshold": thr,
        "n": int(len(g)),
        "valid_frac": float(len(g) / len(df)),
        "ce_mean": float(np.nanmean(ce_valid)),
        "ce_median": q50,
        "ce_iqr": iqr,
        "ce_mad": mad,
        "ce_p05": q05,
        "ce_p95": q95,
        "ce_tail_width": tail_width,
        "cs_mean": float(np.nanmean(cs_valid)),
        "cs_median": float(np.nanmedian(cs_valid))
    })

thr_df = pd.DataFrame(thr_rows).sort_values("threshold").reset_index(drop=True)
thr_df.to_csv(os.path.join(OUT_DIR, "threshold_sweep_summary.csv"), index=False)

# ============================================================
# 7) Ranking stability relative to REF_THR
# ============================================================
print("\nComputing city-rank stability relative to threshold =", REF_THR)

if REF_THR not in city_tables:
    raise RuntimeError(f"❌ Reference threshold {REF_THR} not found in city_tables.")

ref_city = city_tables[REF_THR][["city", "city_ce_mean", "city_ce_median", "city_cs_mean", "city_cs_median"]].copy()
ref_city = ref_city.rename(columns={
    "city_ce_mean": "ref_ce_mean",
    "city_ce_median": "ref_ce_median",
    "city_cs_mean": "ref_cs_mean",
    "city_cs_median": "ref_cs_median"
})

rank_rows = []
for thr, ct in city_tables.items():
    merged = ct.merge(ref_city, on="city", how="inner")

    if len(merged) < 10:
        continue

    # top/bottom overlap by city_ce_mean
    topn = min(10, len(merged) // 3)
    ref_top = set(merged.sort_values("ref_ce_mean").tail(topn)["city"])
    ref_bottom = set(merged.sort_values("ref_ce_mean").head(topn)["city"])

    cur_top = set(merged.sort_values("city_ce_mean").tail(topn)["city"])
    cur_bottom = set(merged.sort_values("city_ce_mean").head(topn)["city"])

    rank_rows.append({
        "threshold": thr,
        "n_city": int(len(merged)),
        "ce_mean_spearman_vs_ref": safe_corr(merged["city_ce_mean"], merged["ref_ce_mean"], method="spearman"),
        "ce_median_spearman_vs_ref": safe_corr(merged["city_ce_median"], merged["ref_ce_median"], method="spearman"),
        "cs_mean_spearman_vs_ref": safe_corr(merged["city_cs_mean"], merged["ref_cs_mean"], method="spearman"),
        "top_overlap_vs_ref": len(ref_top & cur_top) / topn,
        "bottom_overlap_vs_ref": len(ref_bottom & cur_bottom) / topn
    })

rank_df = pd.DataFrame(rank_rows).sort_values("threshold").reset_index(drop=True)
rank_df.to_csv(os.path.join(OUT_DIR, "threshold_city_rank.csv"), index=False)

# ============================================================
# 8) Build a practical stability score
# ============================================================
score_df = thr_df.merge(rank_df, on="threshold", how="left")

score_df["score_valid_frac"] = minmax_scale(score_df["valid_frac"], reverse=False)
score_df["score_iqr"] = minmax_scale(score_df["ce_iqr"], reverse=True)
score_df["score_tail"] = minmax_scale(score_df["ce_tail_width"], reverse=True)
score_df["score_rank"] = minmax_scale(score_df["ce_mean_spearman_vs_ref"].fillna(score_df["ce_mean_spearman_vs_ref"].median()), reverse=False)
score_df["score_overlap"] = minmax_scale(
    score_df[["top_overlap_vs_ref", "bottom_overlap_vs_ref"]].mean(axis=1).fillna(
        score_df[["top_overlap_vs_ref", "bottom_overlap_vs_ref"]].mean(axis=1).median()
    ),
    reverse=False
)

# emphasize stability, but keep sample coverage
score_df["overall_stability_score"] = (
    0.28 * score_df["score_valid_frac"] +
    0.24 * score_df["score_iqr"] +
    0.20 * score_df["score_tail"] +
    0.18 * score_df["score_rank"] +
    0.10 * score_df["score_overlap"]
)

score_df = score_df.sort_values("threshold").reset_index(drop=True)
score_df.to_csv(os.path.join(OUT_DIR, "threshold_stability_score.csv"), index=False)

best_thr_row = score_df.sort_values("overall_stability_score", ascending=False).iloc[0].to_dict()
