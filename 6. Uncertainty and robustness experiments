# 3) Build city-year panel using ORIGINAL active definition
# ============================================================
def build_cityyear_panel(dataset, source_name):
    df = dataset.copy()
    df = df.dropna(subset=["city", "date", "year", "cooling_efficiency"]).copy()

    # baseline Q60 for active
    base = df[(df["year"] >= BASELINE_Y0) & (df["year"] <= BASELINE_Y1)][["city", "cooling_efficiency"]].dropna().copy()
    q60 = (
        base.groupby("city")["cooling_efficiency"]
        .quantile(ACTIVE_Q)
        .rename("ce_q60_baseline")
        .reset_index()
    )
    df = df.merge(q60, on="city", how="left")
    df["active"] = (df["cooling_efficiency"] > df["ce_q60_baseline"]).astype(np.int8)

    candidate_feats = sorted(set(sum(MODEL_SPECS.values(), [])))
    use_feats = [c for c in candidate_feats if c in df.columns]

    agg_dict = {"active": "mean"}
    for c in use_feats:
        agg_dict[c] = "mean"

    panel = (
        df[["city", "year", "active"] + use_feats]
        .dropna(subset=["city", "year", "active"])
        .groupby(["city", "year"], as_index=False)
        .agg(agg_dict)
        .rename(columns={"active": "P_active"})
    )

    panel["period"] = np.nan
    for name, y0, y1 in PERIODS:
        m = (panel["year"] >= y0) & (panel["year"] <= y1)
        panel.loc[m, "period"] = name
    panel = panel.dropna(subset=["period"]).copy()
    panel["period"] = pd.Categorical(panel["period"], categories=[p[0] for p in PERIODS], ordered=True)

    for c in use_feats:
        panel[f"{c}_z"] = zscore_series(panel[c])

    print(f"✅ {source_name} panel: {panel.shape} | cities: {panel['city'].nunique()} | years: ({panel['year'].min()}, {panel['year'].max()})")
    return panel, use_feats

# ============================================================
# 4) Run candidate models for one source
# ============================================================
def run_candidate_models(panel, source_name):
    fit_summary = []
    coef_tables = []

    # save panel
    panel.to_csv(os.path.join(OUT_DIR, f"cityyear_panel_{source_name}.csv"), index=False)

    # global correlation matrix for all candidate features
    all_feats = sorted(set(sum(MODEL_SPECS.values(), [])))
    corr_feats = [c for c in all_feats if c in panel.columns]
    corr = panel[corr_feats].corr()
    corr.to_csv(os.path.join(OUT_DIR, f"corr_candidates_{source_name}.csv"))

    for spec_name, preds in MODEL_SPECS.items():
        preds = [c for c in preds if c in panel.columns]
        if len(preds) == 0:
            continue

        # VIF
        vif_df = compute_vif(panel, [f"{c}_z" for c in preds])
        vif_df.to_csv(os.path.join(OUT_DIR, f"vif_{spec_name}_{source_name}.csv"), index=False)

        # fit model
        formula = make_formula("P_active", preds, with_period_interaction=True)
        fit = smf.ols(formula=formula, data=panel).fit(cov_type=ROBUST_COV)

        me = extract_period_effects(fit, preds)
        me["spec"] = spec_name
        me["source"] = source_name
        coef_tables.append(me)

        fit_summary.append({
            "source": source_name,
            "spec": spec_name,
            "formula": formula,
            "nobs": int(fit.nobs),
            "r2": float(fit.rsquared),
            "r2_adj": float(fit.rsquared_adj)
        })

    coef_df = pd.concat(coef_tables, axis=0, ignore_index=True)
    fit_df = pd.DataFrame(fit_summary)

    coef_df.to_csv(os.path.join(OUT_DIR, f"candidate_twfe_coeffs_{source_name}.csv"), index=False)
    fit_df.to_csv(os.path.join(OUT_DIR, f"candidate_twfe_fit_summary_{source_name}.csv"), index=False)

    return {
        "coef_df": coef_df,
        "fit_df": fit_df,
    }

