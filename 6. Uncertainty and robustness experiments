summary_df = pd.concat(summary_parts, axis=0, ignore_index=True)
cityyear_df = pd.concat(cityyear_parts, axis=0, ignore_index=True)
city_df = pd.concat(city_parts, axis=0, ignore_index=True)

summary_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_scan_summary.csv"), index=False)
cityyear_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_scan_cityyear.csv"), index=False)
city_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_scan_city.csv"), index=False)

print("Saved dense baseline scan.")

# ============================================================
# 7) Rank stability relative to FIXED_0.050
# ============================================================
ref_name = "FIXED_0.050"

rank_contrast_df = add_rank_stability(cityyear_df, ref_name=ref_name, value_col="contrast_mean")
rank_ratio_df = add_rank_stability(cityyear_df, ref_name=ref_name, value_col="ratio_mean")

if len(rank_contrast_df) > 0:
    rank_contrast_df = rank_contrast_df.rename(columns={
        "spearman_rankcorr": "contrast_spearman_rankcorr",
        "pearson_corr": "contrast_pearson_corr",
