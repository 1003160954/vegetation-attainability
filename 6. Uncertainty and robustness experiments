# plot elasticity maps for one representative state: HighWater_HighCanopy
state_plot = "HighWater_HighCanopy"
st = states[state_plot]

fig, axes = plt.subplots(2, 2, figsize=(11.5, 8.8), constrained_layout=True)
axes = axes.ravel()

elas_maps = {}
for i, var in enumerate(elasticity_vars):
    elas, V, S = local_log_elasticity(st, vpd_grid, ssrd_grid, var_name=var, frac=PERT_FRAC)
    elas_maps[var] = elas

all_elas = np.concatenate([elas_maps[v].ravel() for v in elasticity_vars])
elim = float(np.nanquantile(np.abs(all_elas), 0.98))

for ax, var in zip(axes, elasticity_vars):
