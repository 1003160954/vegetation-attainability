        }
        if extra is not None:
            for k, col in extra.items():
                out[k] = float(np.nanmedian(df_cmp[col])) if (col in df_cmp.columns and df_cmp[col].notna().sum() > 0) else np.nan
        return out

    C_rows = []
    C_rows.append(summarize_method(cmp, "ml_deltaLST", "ml_CE"))
