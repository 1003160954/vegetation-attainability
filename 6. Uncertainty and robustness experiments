# water effect at low/high canopy
diff_water_lowcan = surface_store["HighWater_LowCanopy"][0] - surface_store["LowWater_LowCanopy"][0]
diff_water_highcan = surface_store["HighWater_HighCanopy"][0] - surface_store["LowWater_HighCanopy"][0]

