def predict_model_fast(model, X_df):
    X_use = X_df.copy()
    for c in X_use.columns:
        if X_use[c].isna().any():
            X_use[c] = X_use[c].fillna(X_use[c].median())
    return model.predict(X_use.to_numpy(dtype=np.float32)).astype(np.float32)

def compute_counterfactual(df_city, baseline_evi=0.05):
    X_obs = df_city[predictors].copy()
    X_ref = X_obs.copy()
    X_ref[EVI_COL] = baseline_evi

    if pred_obs is not None and len(df_city) == len(sub) and df_city.index.equals(sub.index):
        pred_obs_city = pred_obs.astype(np.float32)
    else:
        pred_obs_city = predict_model_fast(model, X_obs)

    pred_ref_city = predict_model_fast(model, X_ref)

    out = df_city[[CITY, DATE, YEAR, MONTH, EVI_COL, LST_COL]].copy()
    out["LST_pred_obs"] = pred_obs_city
    out["LST_pred_ref"] = pred_ref_city
    out["cooling_strength_pred"] = out["LST_pred_ref"] - out["LST_pred_obs"]
    out["dEVI_ref"] = out[EVI_COL].astype(np.float32) - np.float32(baseline_evi)
    out["cooling_efficiency"] = np.where(
        out["dEVI_ref"].to_numpy(dtype=np.float32) >= np.float32(MIN_DEVI),
        out["cooling_strength_pred"].to_numpy(dtype=np.float32) / out["dEVI_ref"].to_numpy(dtype=np.float32),
        np.nan
    ).astype(np.float32)
    return out

def city_summary_for_selection(df_ce):
    g = df_ce.groupby(CITY, observed=True)
    out = pd.DataFrame({
        "city": list(g.groups.keys()),
        "ce_median": g["cooling_efficiency"].median().values,
        "ce_mean": g["cooling_efficiency"].mean().values,
        "cs_mean": g["cooling_strength_pred"].mean().values
    })
    return out.sort_values("ce_median").reset_index(drop=True)

def build_monthly_climatology(df_ce):
    return (
        df_ce.groupby([CITY, MONTH], observed=True, as_index=False)
        .agg(
            EVI_mean=(EVI_COL, "mean"),
            LST_obs_mean=(LST_COL, "mean"),
            LST_pred_obs_mean=("LST_pred_obs", "mean"),
            LST_pred_ref_mean=("LST_pred_ref", "mean"),
            cooling_strength_mean=("cooling_strength_pred", "mean"),
            cooling_eff_mean=("cooling_efficiency", "mean"),
            dEVI_mean=("dEVI_ref", "mean"),
            n=("cooling_strength_pred", "size")
        )
    )

def safe_spearman(x, y):
    sx = pd.Series(x)
    sy = pd.Series(y)
    if sx.notna().sum() < 10 or sy.notna().sum() < 10:
        return np.nan
    return float(sx.corr(sy, method="spearman"))

def month_name_short(m):
    names = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]
    return names[int(m)-1]

