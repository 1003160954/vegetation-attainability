def zscore_series(x):
    sd = x.std(ddof=0)
    if pd.isna(sd) or sd == 0:
        return pd.Series(np.zeros(len(x)), index=x.index)
    return (x - x.mean()) / sd

def compute_vif(df_in, zcols):
    X = df_in[zcols].dropna().copy()
    if X.empty or len(zcols) < 2:
        return pd.DataFrame({"term": zcols, "VIF": np.nan})
    vals = X.values
    rows = []
    for i, c in enumerate(zcols):
        try:
            vif = variance_inflation_factor(vals, i)
        except Exception:
            vif = np.nan
        rows.append({"term": c, "VIF": vif})
    return pd.DataFrame(rows).sort_values("VIF", ascending=False)

def make_formula(y_col, preds, with_period_interaction=True):
    zpreds = [f"{c}_z" for c in preds]
    if with_period_interaction:
        rhs = "(" + " + ".join(zpreds) + ")*C(period) + C(city) + C(year)"
    else:
        rhs = " + ".join(zpreds) + " + C(city) + C(year)"
    return f"{y_col} ~ {rhs}"

def extract_period_effects(fit, predictors):
    cov = fit.cov_params()
    params = fit.params
    rows = []

    for pred in predictors:
        base = f"{pred}_z"
        for per, _, _ in PERIODS:
            if per == REF_PERIOD:
                beta = float(params.get(base, np.nan))
                var = float(cov.loc[base, base]) if (base in cov.index) else np.nan
            else:
                inter = f"{base}:C(period)[T.{per}]"
                beta = float(params.get(base, 0.0) + params.get(inter, 0.0))
                if (base in cov.index) and (inter in cov.index):
                    var = float(cov.loc[base, base] + cov.loc[inter, inter] + 2 * cov.loc[base, inter])
                elif base in cov.index:
                    var = float(cov.loc[base, base])
                else:
                    var = np.nan

            se = np.sqrt(var) if np.isfinite(var) else np.nan
            ci_low = beta - 1.96 * se if np.isfinite(se) else np.nan
            ci_high = beta + 1.96 * se if np.isfinite(se) else np.nan

            rows.append({
                "predictor": pred,
                "period": per,
                "beta": beta,
                "se": se,
                "ci_low": ci_low,
                "ci_high": ci_high
            })
    return pd.DataFrame(rows)

