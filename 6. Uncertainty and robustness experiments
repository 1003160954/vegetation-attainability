import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# ============================================================
# 0) Paths
# ============================================================
INDIR = "/content/drive/MyDrive/Second_research/MERRA/baseline_dense_scan_enhanced"
OUTDIR = os.path.join(INDIR, "plot_why_choose_005")
os.makedirs(OUTDIR, exist_ok=True)

# ============================================================
# 1) Robust file finder
# ============================================================
def find_first_existing(pattern_list, root_dir):
    for pat in pattern_list:
        hits = sorted(glob.glob(os.path.join(root_dir, pat)))
        if len(hits) > 0:
            return hits[0]
    return None

score_fp = find_first_existing(
    [
        "*score*.csv",
        "*score_table*.csv",
        "dense_baseline_score_table.csv",
        "focused_lowrange_score_table.csv"
    ],
    INDIR
)

summary_fp = find_first_existing(
    [
        "*summary*.csv",
        "*scan_summary*.csv"
    ],
    INDIR
)

if score_fp is None:
    raise FileNotFoundError(f"❌ No score table found in {INDIR}")

print("Using score file :", score_fp)
print("Using summary file:", summary_fp if summary_fp else "None")

# ============================================================
# 2) Load score table
# ============================================================
score = pd.read_csv(score_fp)

# keep only FIXED baselines
score = score[score["baseline"].astype(str).str.startswith("FIXED_")].copy()
if score.empty:
    raise RuntimeError("❌ No FIXED_* baselines found in score table.")

score["baseline_num"] = (
    score["baseline"].astype(str).str.replace("FIXED_", "", regex=False).astype(float)
)

score = score.sort_values("baseline_num").reset_index(drop=True)

# ============================================================
# 3) Build a few composite diagnostic components for panel B
# ============================================================
def minmax_scale(x):
    x = np.asarray(x, dtype=float)
    xmin = np.nanmin(x)
    xmax = np.nanmax(x)
    if np.isclose(xmax, xmin):
        return np.full_like(x, 0.5, dtype=float)
    return (x - xmin) / (xmax - xmin)

# 3.1 overall score (already available)
score["overall_score_norm"] = minmax_scale(score["overall_score"])

# 3.2 valid fraction
score["valid_frac_norm"] = minmax_scale(score["valid_frac"])

# 3.3 ratio stability: smaller IQR = more stable
score["ratio_stability_norm"] = 1 - minmax_scale(score["ratio_iqr"])

# 3.4 rank consistency:
rank_cols = []
if "contrast_spearman_rankcorr" in score.columns:
    rank_cols.append("contrast_spearman_rankcorr")
if "ratio_spearman_rankcorr" in score.columns:
    rank_cols.append("ratio_spearman_rankcorr")

if len(rank_cols) > 0:
    score["rank_consistency_raw"] = score[rank_cols].mean(axis=1)
    score["rank_consistency_norm"] = minmax_scale(score["rank_consistency_raw"])
else:
    score["rank_consistency_raw"] = np.nan
    score["rank_consistency_norm"] = np.nan

# 3.5 extreme overlap
overlap_cols = []
for c in [
    "contrast_top10_overlap", "contrast_bottom10_overlap",
    "ratio_top10_overlap", "ratio_bottom10_overlap"
]:
    if c in score.columns:
        overlap_cols.append(c)

if len(overlap_cols) > 0:
    score["extreme_overlap_raw"] = score[overlap_cols].mean(axis=1)
    score["extreme_overlap_norm"] = minmax_scale(score["extreme_overlap_raw"])
else:
    score["extreme_overlap_raw"] = np.nan
    score["extreme_overlap_norm"] = np.nan

# ============================================================
# 4) Identify best baseline
# ============================================================
