    .reset_index()
    .rename(columns={"pred_full": "pred_mean_full"})
)

for spec, pred in ablation_preds.items():
    tmp = valid_df[[CITY]].copy()
    tmp["pred"] = pred
    city_tmp = tmp.groupby(CITY, observed=True)["pred"].mean().reset_index()
    city_tmp = city_tmp.merge(city_full, on=CITY, how="inner")

    sp = city_tmp["pred"].corr(city_tmp["pred_mean_full"], method="spearman")
    pe = city_tmp["pred"].corr(city_tmp["pred_mean_full"], method="pearson")

    topn = min(10, max(5, len(city_tmp) // 5))
    ref_top = set(city_tmp.sort_values("pred_mean_full", ascending=False).head(topn)[CITY].astype(str))
    ref_bottom = set(city_tmp.sort_values("pred_mean_full", ascending=True).head(topn)[CITY].astype(str))

    cur_top = set(city_tmp.sort_values("pred", ascending=False).head(topn)[CITY].astype(str))
    cur_bottom = set(city_tmp.sort_values("pred", ascending=True).head(topn)[CITY].astype(str))

    city_rank_rows.append({
        "spec": spec,
        "n_city": int(len(city_tmp)),
        "spearman_rankcorr_vs_full": float(sp),
        "pearson_corr_vs_full": float(pe),
        "top_overlap_vs_full": len(ref_top & cur_top) / topn,
        "bottom_overlap_vs_full": len(ref_bottom & cur_bottom) / topn
    })

city_rank_df = pd.DataFrame(city_rank_rows).sort_values("spearman_rankcorr_vs_full", ascending=False).reset_index(drop=True)
city_rank_df.to_csv(os.path.join(OUT_DIR, "city_ranking_stability.csv"), index=False)

