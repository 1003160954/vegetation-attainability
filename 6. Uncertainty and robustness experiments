# -*- coding: utf-8 -*-
# ============================================================
# Mechanistic response-surface + local elasticity experiment
#
# Goal:
#   Test whether cooling efficiency is consistent with a
#   plant-atmosphere biophysical interpretation:
#   CE = f(Demand, Energy, Water, Canopy)
#
# Main outputs:
#   1) Continuous CE response surfaces in VPD × SSRD space
#      under low/high water and low/high canopy states
#   2) Local elasticity maps for VPD, SSRD, SWVL1, EVI
#   3) Summary tables for mechanistic interpretation
#
# Dataset:
#   EVI=0.05 counterfactual version
# ============================================================

import os
import gc
import json
import warnings
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.ensemble import HistGradientBoostingRegressor
from sklearn.model_selection import GroupShuffleSplit
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error

warnings.filterwarnings("ignore")

# ============================================================
# 0) Config
# ============================================================
DATA_FP = "/content/drive/MyDrive/Second_research/derived_datasets/GlobalUrbanCooling_dataset_v3_EVI005_with_lat.parquet"
OUT_DIR = "/content/drive/MyDrive/Second_research/MERRA/mechanistic_surface_EVI005"
os.makedirs(OUT_DIR, exist_ok=True)

CITY = "city"
DATE = "date"
TARGET = "cooling_efficiency"

# core variables
CORE_VARS = [
    "EVI", "LAI",
    "VPD_kPa", "SSRD_MJm2", "SWVL1_m3m3",
    "TP_mm", "T2M_C", "TD_C", "WIND10M_MS",
    "DEM", "DIST_WATER_km", "LC"
]

# safe CE threshold
MIN_DEVI = 0.02

# data controls
MAX_ROWS_PER_CITY = 4000
MAX_TOTAL_ROWS = 250000
RANDOM_STATE = 42
TEST_SIZE = 0.25

# response-surface grid
GRID_N_VPD = 60
GRID_N_SSRD = 60

# elasticity perturbation (log-like small perturbation)
PERT_FRAC = 0.05  # 5%

# model params
MODEL_PARAMS = dict(
    loss="squared_error",
    learning_rate=0.05,
    max_iter=240,
    max_leaf_nodes=31,
    min_samples_leaf=80,
    l2_regularization=0.1,
    random_state=RANDOM_STATE
)

plt.rcParams.update({
    "font.family": "DejaVu Sans",
    "font.size": 10.5,
    "axes.titlesize": 11.5,
    "axes.labelsize": 10.5,
    "xtick.labelsize": 9.3,
    "ytick.labelsize": 9.3,
    "legend.fontsize": 8.5,
    "axes.linewidth": 0.8,
    "figure.dpi": 140,
    "savefig.dpi": 320,
    "svg.fonttype": "none",
})

# ============================================================
# 1) Load data
# ============================================================
df0 = pd.read_parquet(DATA_FP)
print("Loaded:", df0.shape)

required = [CITY, DATE, TARGET, "dEVI_ref"] + CORE_VARS
missing = [c for c in required if c not in df0.columns]
if missing:
    raise ValueError(f"❌ Missing columns: {missing}")

df0[DATE] = pd.to_datetime(df0[DATE], errors="coerce")

df = df0[required].copy()

# numeric conversion
for c in [TARGET, "dEVI_ref"] + CORE_VARS:
    if c != CITY and c != DATE:
        df[c] = pd.to_numeric(df[c], errors="coerce")

# stable CE subset
df = df.dropna(subset=[CITY, TARGET, "dEVI_ref"]).copy()
df = df[df["dEVI_ref"] >= MIN_DEVI].copy()

# keep rows with sufficient predictor support
nonnull_count = df[CORE_VARS].notna().sum(axis=1)
df = df[nonnull_count >= int(0.75 * len(CORE_VARS))].copy()

# fill missing predictors with medians later
df[CITY] = df[CITY].astype("category")

print("After stable CE filter:", df.shape)
print("Cities:", df[CITY].nunique())

# ============================================================
# 2) Balanced sampling
# ============================================================
rng = np.random.default_rng(RANDOM_STATE)
parts = []

for city, g in df.groupby(CITY, observed=True):
    if len(g) > MAX_ROWS_PER_CITY:
        idx = rng.choice(g.index.to_numpy(), size=MAX_ROWS_PER_CITY, replace=False)
        parts.append(df.loc[idx])
    else:
        parts.append(g)

df = pd.concat(parts, axis=0).reset_index(drop=True)

if len(df) > MAX_TOTAL_ROWS:
    df = df.sample(MAX_TOTAL_ROWS, random_state=RANDOM_STATE).reset_index(drop=True)

fill_values = {}
for c in CORE_VARS:
    fill_values[c] = float(df[c].median()) if df[c].notna().any() else 0.0
    df[c] = df[c].fillna(fill_values[c])

print("After balanced sampling:", df.shape)

# ============================================================
# 3) Train/validation split by city
# ============================================================
gss = GroupShuffleSplit(n_splits=1, test_size=TEST_SIZE, random_state=RANDOM_STATE)
tr_idx, va_idx = next(gss.split(df, groups=df[CITY].astype(str)))

train_df = df.iloc[tr_idx].copy()
valid_df = df.iloc[va_idx].copy()

Xtr = train_df[CORE_VARS].to_numpy(dtype=np.float32)
ytr = train_df[TARGET].to_numpy(dtype=np.float32)

Xva = valid_df[CORE_VARS].to_numpy(dtype=np.float32)
yva = valid_df[TARGET].to_numpy(dtype=np.float32)

# ============================================================
# 4) Fit smooth surrogate model
# ============================================================
model = HistGradientBoostingRegressor(**MODEL_PARAMS)
model.fit(Xtr, ytr)
pred_va = model.predict(Xva).astype(np.float32)

print("\nSurrogate model performance:")
print("  R2  =", round(r2_score(yva, pred_va), 4))
print("  MAE =", round(mean_absolute_error(yva, pred_va), 4))
print("  RMSE=", round(np.sqrt(mean_squared_error(yva, pred_va)), 4))

# ============================================================
# 5) Helper functions
# ============================================================
def make_reference_state(df_ref, override=None):
    """
    Construct one representative state vector.
    override: dict of variable -> fixed value
    """
    ref = {c: float(df_ref[c].median()) for c in CORE_VARS}
    # LC should be integer-like if possible
    if "LC" in ref:
        ref["LC"] = int(round(ref["LC"]))
    if override is not None:
        ref.update(override)
    return ref

def make_surface_df(base_state, vpd_grid, ssrd_grid):
    V, S = np.meshgrid(vpd_grid, ssrd_grid)
    n = V.size

    dat = {c: np.full(n, base_state[c], dtype=float) for c in CORE_VARS}
    dat["VPD_kPa"] = V.ravel()
    dat["SSRD_MJm2"] = S.ravel()

    X = pd.DataFrame(dat)
    return X, V, S

def predict_surface(base_state, vpd_grid, ssrd_grid):
    Xsurf, V, S = make_surface_df(base_state, vpd_grid, ssrd_grid)
    pred = model.predict(Xsurf[CORE_VARS].to_numpy(dtype=np.float32)).reshape(V.shape)
    return pred, V, S

def local_log_elasticity(base_state, vpd_grid, ssrd_grid, var_name, frac=0.05, floor=1e-6):
    """
    elasticity = d log(CE) / d log(X)
    via symmetric finite difference
    """
    X0, V, S = make_surface_df(base_state, vpd_grid, ssrd_grid)

    x = X0[var_name].to_numpy(dtype=float)
    dx = np.maximum(np.abs(x) * frac, floor)

    Xp = X0.copy()
    Xm = X0.copy()
    Xp[var_name] = x + dx
    Xm[var_name] = np.maximum(x - dx, floor)

    yp = model.predict(Xp[CORE_VARS].to_numpy(dtype=np.float32))
    ym = model.predict(Xm[CORE_VARS].to_numpy(dtype=np.float32))

    # keep CE positive-ish for log elasticity interpretation
    yp = np.maximum(yp, floor)
    ym = np.maximum(ym, floor)

    logy_diff = np.log(yp) - np.log(ym)
    logx_diff = np.log(np.maximum(Xp[var_name].to_numpy(dtype=float), floor)) - np.log(np.maximum(Xm[var_name].to_numpy(dtype=float), floor))

    elas = (logy_diff / np.maximum(logx_diff, floor)).reshape(V.shape)
    return elas, V, S

def save_surface_summary(arr, V, S, label):
    q = np.nanquantile(arr, [0.05, 0.25, 0.50, 0.75, 0.95])
    return {
        "label": label,
        "min": float(np.nanmin(arr)),
        "p05": float(q[0]),
        "p25": float(q[1]),
        "median": float(q[2]),
        "p75": float(q[3]),
        "p95": float(q[4]),
        "max": float(np.nanmax(arr)),
        "peak_vpd": float(V.ravel()[np.nanargmax(arr)]),
        "peak_ssrd": float(S.ravel()[np.nanargmax(arr)])
    }

def draw_surface(ax, arr, V, S, title, cmap="viridis", vmin=None, vmax=None):
    im = ax.pcolormesh(V, S, arr, shading="auto", cmap=cmap, vmin=vmin, vmax=vmax)
    ax.set_xlabel("VPD (kPa)")
    ax.set_ylabel("SSRD (MJ m$^{-2}$)")
    ax.set_title(title)
    return im

# ============================================================
# 6) Define physically meaningful reference states
# ============================================================
# use quantiles rather than naive split labels
evi_low = float(df["EVI"].quantile(0.25))
evi_high = float(df["EVI"].quantile(0.75))
sw_low = float(df["SWVL1_m3m3"].quantile(0.25))
sw_high = float(df["SWVL1_m3m3"].quantile(0.75))

vpd_grid = np.linspace(float(df["VPD_kPa"].quantile(0.02)), float(df["VPD_kPa"].quantile(0.98)), GRID_N_VPD)
ssrd_grid = np.linspace(float(df["SSRD_MJm2"].quantile(0.02)), float(df["SSRD_MJm2"].quantile(0.98)), GRID_N_SSRD)

states = {
    "LowWater_LowCanopy": make_reference_state(df, override={"SWVL1_m3m3": sw_low, "EVI": evi_low}),
    "HighWater_LowCanopy": make_reference_state(df, override={"SWVL1_m3m3": sw_high, "EVI": evi_low}),
    "LowWater_HighCanopy": make_reference_state(df, override={"SWVL1_m3m3": sw_low, "EVI": evi_high}),
    "HighWater_HighCanopy": make_reference_state(df, override={"SWVL1_m3m3": sw_high, "EVI": evi_high}),
}

# if LAI available, align LAI crudely with EVI state
lai_low = float(df["LAI"].quantile(0.25))
lai_high = float(df["LAI"].quantile(0.75))
states["LowWater_LowCanopy"]["LAI"] = lai_low
states["HighWater_LowCanopy"]["LAI"] = lai_low
states["LowWater_HighCanopy"]["LAI"] = lai_high
states["HighWater_HighCanopy"]["LAI"] = lai_high

# ============================================================
# 7) Continuous response surfaces
# ============================================================
surface_summaries = []
surface_store = {}

for label, st in states.items():
    arr, V, S = predict_surface(st, vpd_grid, ssrd_grid)
    surface_store[label] = (arr, V, S)
    surface_summaries.append(save_surface_summary(arr, V, S, label))

surface_summary_df = pd.DataFrame(surface_summaries)
surface_summary_df.to_csv(os.path.join(OUT_DIR, "response_surface_summary.csv"), index=False)

# common color scale
all_vals = np.concatenate([surface_store[k][0].ravel() for k in surface_store])
vmin = float(np.nanquantile(all_vals, 0.02))
vmax = float(np.nanquantile(all_vals, 0.98))

fig, axes = plt.subplots(2, 2, figsize=(11.5, 8.8), constrained_layout=True)
axes = axes.ravel()

for ax, (label, (arr, V, S)) in zip(axes, surface_store.items()):
    im = draw_surface(ax, arr, V, S, label.replace("_", " · "), cmap="viridis", vmin=vmin, vmax=vmax)

cbar = fig.colorbar(im, ax=axes.tolist(), shrink=0.94)
