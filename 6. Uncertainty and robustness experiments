    })
    rank_contrast_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_rank_stability_contrast.csv"), index=False)

if len(rank_ratio_df) > 0:
    rank_ratio_df = rank_ratio_df.rename(columns={
        "spearman_rankcorr": "ratio_spearman_rankcorr",
        "pearson_corr": "ratio_pearson_corr",
        "n_city": "ratio_n_city"
    })
    rank_ratio_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_rank_stability_ratio.csv"), index=False)

# ============================================================
# 8) Top / Bottom overlap
# ============================================================
overlap_contrast_df = add_top_bottom_overlap(city_df, ref_name=ref_name, value_col="city_contrast_mean", topn=10)
overlap_ratio_df = add_top_bottom_overlap(city_df, ref_name=ref_name, value_col="city_ratio_mean", topn=10)

if len(overlap_contrast_df) > 0:
    overlap_contrast_df = overlap_contrast_df.rename(columns={
        "bottom10_overlap": "contrast_bottom10_overlap",
        "top10_overlap": "contrast_top10_overlap"
    })
    overlap_contrast_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_overlap_contrast.csv"), index=False)

if len(overlap_ratio_df) > 0:
    overlap_ratio_df = overlap_ratio_df.rename(columns={
        "bottom10_overlap": "ratio_bottom10_overlap",
        "top10_overlap": "ratio_top10_overlap"
    })
    overlap_ratio_df.to_csv(os.path.join(OUT_DIR, "dense_baseline_overlap_ratio.csv"), index=False)

# ============================================================
# 9) Build enhanced score table
# ============================================================
score_df = summary_df[summary_df["thr"] == 0.02].copy()

if len(rank_contrast_df) > 0:
    score_df = score_df.merge(
        rank_contrast_df[["baseline", "contrast_spearman_rankcorr", "contrast_pearson_corr"]],
