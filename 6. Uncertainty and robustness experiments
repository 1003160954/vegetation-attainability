        vpd_grid = np.linspace(float(base_df["VPD_kPa"].quantile(0.05)), float(base_df["VPD_kPa"].quantile(0.95)), 35)
        ssrd_grid = np.linspace(float(base_df["SSRD_MJm2"].quantile(0.05)), float(base_df["SSRD_MJm2"].quantile(0.95)), 35)
        V, S = np.meshgrid(vpd_grid, ssrd_grid)

        dat = {c: np.full(V.size, base[c], dtype=float) for c in feat_cols}
        if "VPD_kPa" in feat_cols:
            dat["VPD_kPa"] = V.ravel()
        if "SSRD_MJm2" in feat_cols:
            dat["SSRD_MJm2"] = S.ravel()

        X = pd.DataFrame(dat)
        pred = model_obj.predict(X[feat_cols]).reshape(V.shape)
        return pred, V, S

