            )
        )

    C_df = pd.DataFrame(C_rows)
    C_df.to_csv(C_METRIC_FP, index=False)

    ml_city = (
        cmp.groupby(CITY, observed=True)["ml_CE"]
        .mean()
        .reset_index()
        .rename(columns={"ml_CE": "ml_city_ce"})
    )

