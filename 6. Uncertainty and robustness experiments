plt.savefig(os.path.join(OUT_DIR, "Fig_step3_correlation_matrix.svg"), bbox_inches="tight")
plt.close(fig)

# ============================================================
# 5) VIF
# ============================================================
print("\nComputing VIF ...")

def compute_vif_table(df_num):
    from statsmodels.stats.outliers_influence import variance_inflation_factor

    X = df_num.copy()
    X = X.dropna(axis=1, how="all")
    X = X.loc[:, X.std() > 0].copy()

    vif_rows = []
    cols = X.columns.tolist()
    Xv = X.to_numpy(dtype=float)

    for i, c in enumerate(cols):
        try:
            vif = variance_inflation_factor(Xv, i)
        except Exception:
            vif = np.nan
        vif_rows.append({"variable": c, "VIF": float(vif) if np.isfinite(vif) else np.nan})

    return pd.DataFrame(vif_rows).sort_values("VIF", ascending=False).reset_index(drop=True)

vif_vars = [c for c in ["T2M_C", "TD_C", "VPD_kPa", "SSRD_MJm2", "TP_mm", "SWVL1_m3m3", "WIND10M_MS", "EVI", "LAI"] if c in df_s.columns]
vif_df = compute_vif_table(df_s[vif_vars])
vif_df.to_csv(os.path.join(OUT_DIR, "vif_table.csv"), index=False)

# ============================================================
# 6) Train/validation split by city
# ============================================================
gss = GroupShuffleSplit(n_splits=1, test_size=TEST_SIZE, random_state=RANDOM_STATE)
split = next(gss.split(df_s, groups=df_s[CITY].astype(str)))
tr_idx, va_idx = split

train_df = df_s.iloc[tr_idx].copy()
valid_df = df_s.iloc[va_idx].copy()

print("\nTrain:", train_df.shape, "| Valid:", valid_df.shape)
print("Train cities:", train_df[CITY].nunique(), "| Valid cities:", valid_df[CITY].nunique())

# ============================================================
# 7) Model fit helper
# ============================================================
def fit_and_eval(train_df, valid_df, feature_cols, target_col):
    model = HistGradientBoostingRegressor(**MODEL_PARAMS)

    Xtr = train_df[feature_cols].to_numpy(dtype=np.float32)
    ytr = train_df[target_col].to_numpy(dtype=np.float32)

    Xva = valid_df[feature_cols].to_numpy(dtype=np.float32)
    yva = valid_df[target_col].to_numpy(dtype=np.float32)

    model.fit(Xtr, ytr)
    pred = model.predict(Xva).astype(np.float32)

    out = {
        "model": model,
        "pred_valid": pred,
        "R2": float(r2_score(yva, pred)),
        "MAE": float(mean_absolute_error(yva, pred)),
        "RMSE": float(np.sqrt(mean_squared_error(yva, pred))),
        "n_features": len(feature_cols)
    }
    return out

# ============================================================
# 8) Full model
# ============================================================
print("\nFitting full model ...")
full_features = all_predictors.copy()
full_res = fit_and_eval(train_df, valid_df, full_features, target)

print("Full model:")
print("  R2  =", round(full_res["R2"], 4))
print("  MAE =", round(full_res["MAE"], 4))
print("  RMSE=", round(full_res["RMSE"], 4))

# ============================================================
# 9) Reduced models: single-variable and process-group ablations
# ============================================================
print("\nFitting ablation models ...")

ablation_specs = {}

for v in ["T2M_C", "TD_C", "VPD_kPa"]:
    if v in full_features:
        ablation_specs[f"drop_{v}"] = [c for c in full_features if c != v]

for g, cols in group_vars.items():
    remain = [c for c in full_features if c not in cols]
    if len(remain) >= 2:
        ablation_specs[f"drop_group_{g}"] = remain

ablation_rows = []
ablation_preds = {}

ablation_rows.append({
    "spec": "full_model",
    "n_features": len(full_features),
    "R2": full_res["R2"],
    "MAE": full_res["MAE"],
    "RMSE": full_res["RMSE"],
    "delta_R2_vs_full": 0.0,
    "delta_RMSE_vs_full": 0.0
})
ablation_preds["full_model"] = full_res["pred_valid"]

for spec, feat_cols in ablation_specs.items():
    res = fit_and_eval(train_df, valid_df, feat_cols, target)
    ablation_rows.append({
        "spec": spec,
        "n_features": len(feat_cols),
        "R2": res["R2"],
        "MAE": res["MAE"],
        "RMSE": res["RMSE"],
        "delta_R2_vs_full": res["R2"] - full_res["R2"],
        "delta_RMSE_vs_full": res["RMSE"] - full_res["RMSE"]
    })
    ablation_preds[spec] = res["pred_valid"]
    print(spec, "done")

ablation_df = pd.DataFrame(ablation_rows).sort_values("delta_R2_vs_full").reset_index(drop=True)
ablation_df.to_csv(os.path.join(OUT_DIR, "ablation_model_comparison.csv"), index=False)

# ============================================================
# 10) Grouped permutation importance
# ============================================================
print("\nComputing grouped permutation importance ...")

Xva_full = valid_df[full_features].copy().reset_index(drop=True)
yva_full = valid_df[target].to_numpy(dtype=np.float32)
pred_full = full_res["pred_valid"]

base_r2 = float(r2_score(yva_full, pred_full))
base_rmse = float(np.sqrt(mean_squared_error(yva_full, pred_full)))

rng = np.random.default_rng(RANDOM_STATE)
group_perm_rows = []

for gname, gcols in group_vars.items():
    use_cols = [c for c in gcols if c in Xva_full.columns]
    if len(use_cols) == 0:
        continue

    r2_drop_list = []
    rmse_inc_list = []

    for rep in range(N_REPEATS_PERM):
        Xp = Xva_full.copy()
        perm_idx = rng.permutation(len(Xp))
        for c in use_cols:
            Xp[c] = Xp[c].to_numpy()[perm_idx]

        pred_perm = full_res["model"].predict(Xp.to_numpy(dtype=np.float32)).astype(np.float32)

        r2_perm = float(r2_score(yva_full, pred_perm))
        rmse_perm = float(np.sqrt(mean_squared_error(yva_full, pred_perm)))

        r2_drop_list.append(base_r2 - r2_perm)
        rmse_inc_list.append(rmse_perm - base_rmse)

    group_perm_rows.append({
        "group": gname,
        "variables": ", ".join(use_cols),
        "n_variables": len(use_cols),
        "delta_R2_mean": float(np.mean(r2_drop_list)),
        "delta_R2_std": float(np.std(r2_drop_list)),
        "delta_RMSE_mean": float(np.mean(rmse_inc_list)),
        "delta_RMSE_std": float(np.std(rmse_inc_list))
    })

group_perm_df = pd.DataFrame(group_perm_rows).sort_values("delta_R2_mean", ascending=False).reset_index(drop=True)
group_perm_df.to_csv(os.path.join(OUT_DIR, "grouped_permutation_importance.csv"), index=False)

# ============================================================
# 11) City-level ranking stability
# ============================================================
print("\nComputing city-level ranking stability ...")

city_base = valid_df[[CITY, target]].copy()
city_base["pred_full"] = ablation_preds["full_model"]

city_rank_rows = []

city_full = (
    city_base.groupby(CITY, observed=True)["pred_full"]
