# -*- coding: utf-8 -*-
# ============================================================
# Dense fixed-baseline scan: 0.000–0.100 with step 0.005
# Purpose:
#   Evaluate whether 0.05 is the best practical counterfactual
#   EVI baseline under trade-offs among:
#     - valid sample fraction
#     - ratio stability
#     - city-rank robustness
#     - top/bottom city overlap
#     - practical interpretability
# ============================================================

import os
import gc
import json
import warnings
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.ensemble import HistGradientBoostingRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

warnings.filterwarnings("ignore")

# ============================================================
# 0) Paths
# ============================================================
DATA_FP = "/content/drive/MyDrive/Second_research/MERRA/hybrid/GlobalUrbanCooling_dataset_v2_ERA5_plus_MERRA2hybrid.parquet"
OUT_DIR = "/content/drive/MyDrive/Second_research/MERRA/baseline_dense_scan_enhanced"
os.makedirs(OUT_DIR, exist_ok=True)

# ============================================================
# 1) Load needed columns
# ============================================================
need_cols = [
    "city", "date", "EVI", "LST",
    "T2M_C", "TD_C", "VPD_kPa", "SSRD_MJm2",
    "TP_mm", "SWVL1_m3m3", "WIND10M_MS"
]

df = pd.read_parquet(DATA_FP, columns=need_cols)

df["city"] = df["city"].astype("category")
df["date"] = pd.to_datetime(df["date"], errors="coerce")

num_cols = [c for c in need_cols if c not in ["city", "date"]]
for c in num_cols:
    df[c] = pd.to_numeric(df[c], errors="coerce").astype("float32")

df = df.dropna(subset=["city", "date", "EVI", "LST", "T2M_C"]).copy()
df["year"] = df["date"].dt.year.astype("int16")
df["month"] = df["date"].dt.month.astype("int8")
df = df[(df["EVI"] >= -0.2) & (df["EVI"] <= 1.0)].copy()

print("After clean:", df.shape)

# ============================================================
# 2) Summer subset
# ============================================================
years_all = sorted(df["year"].unique().tolist())
if set(range(2002, 2007)).issubset(set(years_all)):
    baseline_years = list(range(2002, 2007))
else:
    baseline_years = years_all[:min(5, len(years_all))]

print("Baseline years:", baseline_years)

base = df[df["year"].isin(baseline_years)][["city", "month", "T2M_C"]].copy()

m = (
    base.groupby(["city", "month"], observed=True)["T2M_C"]
    .mean()
    .reset_index()
    .sort_values(["city", "T2M_C"], ascending=[True, False])
)
m["rank"] = m.groupby("city", observed=True).cumcount() + 1

# top-3 hottest months as summer
summer_def = m[m["rank"] <= 3][["city", "month"]].copy()
summer_def["is_summer"] = 1

df = df.merge(summer_def, on=["city", "month"], how="left")
df["is_summer"] = df["is_summer"].fillna(0).astype("int8")
df = df[df["is_summer"] == 1].copy()

print("Summer subset:", df.shape)

# ============================================================
# 3) Train conditional LST model
# ============================================================
predictors = ["EVI", "T2M_C", "TD_C", "VPD_kPa", "SSRD_MJm2", "TP_mm", "SWVL1_m3m3", "WIND10M_MS"]
train_df = df.dropna(subset=predictors + ["LST"]).copy()

MAX_TRAIN = 600_000
if len(train_df) > MAX_TRAIN:
    train_df = train_df.sample(MAX_TRAIN, random_state=42)

X = train_df[predictors].to_numpy(dtype=np.float32)
y = train_df["LST"].to_numpy(dtype=np.float32)

Xtr, Xva, ytr, yva = train_test_split(X, y, test_size=0.15, random_state=42)

model = HistGradientBoostingRegressor(
    loss="squared_error",
    learning_rate=0.05,
    max_iter=250,
    max_leaf_nodes=31,
    min_samples_leaf=80,
    l2_regularization=0.1,
    random_state=42
)
model.fit(Xtr, ytr)
pred_va = model.predict(Xva)

print("\nConditional LST model:")
print("  valid R2  =", round(r2_score(yva, pred_va), 4))
print("  valid MAE =", round(mean_absolute_error(yva, pred_va), 4))
print("  valid RMSE=", round(np.sqrt(mean_squared_error(yva, pred_va)), 4))

# ============================================================
# 4) Prediction subset
# ============================================================
sub = df.dropna(subset=predictors).copy()

MAX_PRED = 600_000
if len(sub) > MAX_PRED:
    sub = sub.sample(MAX_PRED, random_state=42)

X_obs = sub[predictors].copy()
pred_obs = model.predict(X_obs.to_numpy(dtype=np.float32)).astype("float32")
sub["LST_pred_obs"] = pred_obs

obs_evi = sub["EVI"].to_numpy(dtype=np.float32)
ratio_thresholds = [0.01, 0.02, 0.03]

print("Prediction subset:", sub.shape)

# ============================================================
# 5) Helpers
# ============================================================
def summarize_baseline(name, evi_base_arr):
    """
    Returns:
      summary_df: per-threshold summary
      cityyear_df: city-year mean tables for contrast and CE rank stability
      city_df: city-level summary for top/bottom overlap
    """
    X_cf = X_obs.copy()
    X_cf["EVI"] = evi_base_arr.astype("float32")

    pred_cf = model.predict(X_cf.to_numpy(dtype=np.float32)).astype("float32")
    contrast = (pred_cf - pred_obs).astype("float32")
    dEVI = obs_evi - evi_base_arr.astype("float32")

    summary_rows = []
    for thr in ratio_thresholds:
        valid = dEVI >= thr

        if valid.sum() == 0:
            summary_rows.append({
                "baseline": name,
                "thr": thr,
                "n": int(len(dEVI)),
                "valid_n": 0,
                "valid_frac": 0.0,
                "contrast_mean": np.nan,
                "contrast_median": np.nan,
                "contrast_std": np.nan,
                "contrast_p95": np.nan,
                "dEVI_median": np.nan,
                "ratio_mean": np.nan,
                "ratio_median": np.nan,
                "ratio_p05": np.nan,
                "ratio_p95": np.nan,
                "ratio_iqr": np.nan,
                "baseline_mean": float(np.nanmean(evi_base_arr)),
                "baseline_median": float(np.nanmedian(evi_base_arr)),
            })
        else:
            ratio_valid = contrast[valid] / dEVI[valid]
            summary_rows.append({
                "baseline": name,
                "thr": thr,
                "n": int(len(dEVI)),
                "valid_n": int(valid.sum()),
                "valid_frac": float(valid.mean()),
                "contrast_mean": float(np.nanmean(contrast)),
                "contrast_median": float(np.nanmedian(contrast)),
                "contrast_std": float(np.nanstd(contrast)),
                "contrast_p95": float(np.nanquantile(contrast, 0.95)),
                "dEVI_median": float(np.nanmedian(dEVI[valid])),
                "ratio_mean": float(np.nanmean(ratio_valid)),
                "ratio_median": float(np.nanmedian(ratio_valid)),
                "ratio_p05": float(np.nanquantile(ratio_valid, 0.05)),
                "ratio_p95": float(np.nanquantile(ratio_valid, 0.95)),
                "ratio_iqr": float(np.nanquantile(ratio_valid, 0.75) - np.nanquantile(ratio_valid, 0.25)),
                "baseline_mean": float(np.nanmean(evi_base_arr)),
                "baseline_median": float(np.nanmedian(evi_base_arr)),
            })

    # city-year for rank stability
    cityyear_df = pd.DataFrame({
        "city": sub["city"].astype(str).values,
        "year": sub["year"].values,
        "contrast_mean_raw": contrast,
        "ratio_valid_raw": np.where(dEVI >= 0.02, contrast / dEVI, np.nan)
    })

    cityyear_df = (
        cityyear_df.groupby(["city", "year"], as_index=False)
        .agg({
            "contrast_mean_raw": "mean",
            "ratio_valid_raw": "mean"
        })
        .rename(columns={
            "contrast_mean_raw": "contrast_mean",
            "ratio_valid_raw": "ratio_mean"
        })
    )
    cityyear_df["baseline"] = name

    # city-level summary for overlap
    city_df = pd.DataFrame({
        "city": sub["city"].astype(str).values,
        "contrast_raw": contrast,
        "ratio_valid_raw": np.where(dEVI >= 0.02, contrast / dEVI, np.nan)
    })

    city_df = (
        city_df.groupby("city", as_index=False)
        .agg({
            "contrast_raw": "mean",
            "ratio_valid_raw": "mean"
        })
        .rename(columns={
            "contrast_raw": "city_contrast_mean",
            "ratio_valid_raw": "city_ratio_mean"
        })
    )
    city_df["baseline"] = name

    return pd.DataFrame(summary_rows), cityyear_df, city_df


def rank_corr_from_wide(wide, ref_name):
    rows = []
    if ref_name not in wide.columns:
        return pd.DataFrame(rows)

    ref_series = wide[ref_name]

    for col in wide.columns:
        common = pd.concat([ref_series, wide[col]], axis=1, join="inner").dropna()
        if len(common) < 10:
            continue

        s1 = common.iloc[:, 0]
        s2 = common.iloc[:, 1]

        rows.append({
            "baseline": col,
            "ref_baseline": ref_name,
            "spearman_rankcorr": float(s1.corr(s2, method="spearman")),
            "pearson_corr": float(s1.corr(s2, method="pearson")),
            "n_city": int(len(common))
        })
    return pd.DataFrame(rows)


def add_rank_stability(scan_cityyear, ref_name, value_col):
    """
    value_col: 'contrast_mean' or 'ratio_mean'
    """
    citymean = (
        scan_cityyear.groupby(["baseline", "city"], as_index=False)[value_col]
        .mean()
    )

    wide = citymean.pivot(index="city", columns="baseline", values=value_col)
    return rank_corr_from_wide(wide, ref_name)


def add_top_bottom_overlap(city_df_all, ref_name, value_col, topn=10):
    """
    value_col: 'city_contrast_mean' or 'city_ratio_mean'
    """
    rows = []
    ref = city_df_all[city_df_all["baseline"] == ref_name][["city", value_col]].dropna().copy()
    if len(ref) < topn:
        return pd.DataFrame(rows)

    ref = ref.sort_values(value_col)
    ref_bottom = set(ref.head(topn)["city"].tolist())
    ref_top = set(ref.tail(topn)["city"].tolist())

    for b in sorted(city_df_all["baseline"].unique()):
        cur = city_df_all[city_df_all["baseline"] == b][["city", value_col]].dropna().copy()
        if len(cur) < topn:
            continue
        cur = cur.sort_values(value_col)

        cur_bottom = set(cur.head(topn)["city"].tolist())
        cur_top = set(cur.tail(topn)["city"].tolist())

        rows.append({
            "baseline": b,
            "ref_baseline": ref_name,
            f"bottom{topn}_overlap": len(ref_bottom & cur_bottom) / topn,
            f"top{topn}_overlap": len(ref_top & cur_top) / topn
        })

    return pd.DataFrame(rows)


def minmax_scale(s, reverse=False):
    s = s.astype(float)
    mn = s.min()
    mx = s.max()
    if pd.isna(mn) or pd.isna(mx) or (mx - mn) == 0:
        out = pd.Series(np.ones(len(s)), index=s.index)
    else:
        out = (s - mn) / (mx - mn)
    if reverse:
        out = 1 - out
    return out

# ============================================================
# 6) Dense baseline set
# ============================================================
baseline_grid = np.round(np.arange(0.000, 0.1001, 0.005), 3).tolist()

summary_parts = []
cityyear_parts = []
city_parts = []

print("\nRunning dense fixed-baseline scan ...")
for b in baseline_grid:
    name = f"FIXED_{b:.3f}"
    evi_base = np.full(len(sub), b, dtype=np.float32)
    s, cy, cc = summarize_baseline(name, evi_base)
