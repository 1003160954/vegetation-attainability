# 2.1 HighCE threshold sensitivity: Fig.3 curves + city divergence
# ----------------------------

highce_fig3_rows = []
highce_summary_rows = []
div_rows = []

for source, ce_col in ce_cols_renamed.items():

    for high_q in HIGHCE_Q_LIST:

        d = ce_summer.copy()
        d = d[np.isfinite(d[ce_col])].copy()

        thr = (
            d.groupby("city")[ce_col]
            .quantile(high_q)
            .rename("high_thr")
            .reset_index()
        )

        d = d.merge(thr, on="city", how="left")
        d["HighCE_sens"] = (d[ce_col] >= d["high_thr"]).astype(int)
        d["period"] = d["Year"].apply(classify_period)

        city_bin = compute_fig3_city_bin(d, ce_col, "HighCE_sens")
        global_bin = aggregate_fig3_no_boot(city_bin)

        global_bin["source"] = source
        global_bin["high_q"] = high_q
        global_bin["top_fraction"] = 1 - high_q
        highce_fig3_rows.append(global_bin)

        # summarize Fig.3 structure
        for ssrd in SSRD_ORDER:
            sub = global_bin[global_bin["SSRD_group"] == ssrd].sort_values("vpd_bin")
            if len(sub) < 3:
                continue

            peak_row = sub.loc[sub["Pr_HighState_med"].idxmax()]

            highce_summary_rows.append({
                "source": source,
                "high_q": high_q,
                "top_fraction": 1 - high_q,
                "SSRD_group": ssrd,
                "CE_p90_lowVPD": sub.iloc[0]["metric_p90_med"],
                "CE_p90_highVPD": sub.iloc[-1]["metric_p90_med"],
                "CE_p90_change": sub.iloc[-1]["metric_p90_med"] - sub.iloc[0]["metric_p90_med"],
                "PrHigh_lowVPD": sub.iloc[0]["Pr_HighState_med"],
                "PrHigh_highVPD": sub.iloc[-1]["Pr_HighState_med"],
                "PrHigh_peak": peak_row["Pr_HighState_med"],
                "PrHigh_peak_bin": int(peak_row["vpd_bin"]),
                "n_curve_points": len(sub),
            })

        # city divergence under this threshold
        d["VPD_group"] = d.groupby("city")["VPD_kPa"].transform(city_tercile_labels)

        city_avg = (
            d[d["period"].isin(["early", "recent"])]
            .groupby(["city", "period"])
            .agg(PrHigh_avg=("HighCE_sens", "mean"))
            .reset_index()
        )

        city_ext = (
            d[(d["VPD_group"] == "high") & (d["period"].isin(["early", "recent"]))]
            .groupby(["city", "period"])
            .agg(PrHigh_extreme=("HighCE_sens", "mean"))
            .reset_index()
        )

        cd = city_avg.merge(city_ext, on=["city", "period"], how="outer")
        wide = cd.pivot(index="city", columns="period")
        wide.columns = [f"{a}_{b}" for a, b in wide.columns]
        wide = wide.reset_index()

        needed = [
            "PrHigh_avg_early", "PrHigh_avg_recent",
            "PrHigh_extreme_early", "PrHigh_extreme_recent",
        ]
        for x in needed:
            if x not in wide.columns:
                wide[x] = np.nan

        wide["d_avg"] = wide["PrHigh_avg_recent"] - wide["PrHigh_avg_early"]
        wide["d_extreme"] = wide["PrHigh_extreme_recent"] - wide["PrHigh_extreme_early"]
        wide["div_type"] = [classify_quad(x, y) for x, y in zip(wide["d_avg"], wide["d_extreme"])]

        valid = wide.dropna(subset=["d_avg", "d_extreme"]).copy()

        if len(valid) > 5:
            r, p = spearmanr(valid["d_avg"], valid["d_extreme"])
        else:
            r, p = np.nan, np.nan

        counts = valid["div_type"].value_counts()

        div_rows.append({
            "source": source,
            "high_q": high_q,
            "top_fraction": 1 - high_q,
            "n_cities": len(valid),
            "spearman_r": r,
            "spearman_p": p,
            "gain_both": int(counts.get("gain_both", 0)),
            "gain_avg_lose_extreme": int(counts.get("gain_avg_lose_extreme", 0)),
            "lose_both": int(counts.get("lose_both", 0)),
            "lose_avg_gain_extreme": int(counts.get("lose_avg_gain_extreme", 0)),
        })

