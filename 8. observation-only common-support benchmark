def summarize_curve_table(df, method_label, curve_type="balanced"):
    """
    Generic summary for tables with columns:
      SSRD_group, metric_p90_med or CE_p90_ens,
      Pr_HighState_med or Pr_HighCE_ens,
      CI columns, n_cities
    """
    if df is None or len(df) == 0:
        return pd.DataFrame()

    d = df.copy()

    # Harmonize column names
    if "CE_p90_ens" in d.columns:
        d["metric_p90_med"] = d["CE_p90_ens"]
    if "Pr_HighCE_ens" in d.columns:
        d["Pr_HighState_med"] = d["Pr_HighCE_ens"]
    if "CE_p90_lo" in d.columns and "CE_p90_hi" in d.columns:
        d["metric_p90_lo95"] = d["CE_p90_lo"]
        d["metric_p90_hi95"] = d["CE_p90_hi"]
    if "Pr_HighCE_lo" in d.columns and "Pr_HighCE_hi" in d.columns:
        d["Pr_HighState_lo95"] = d["Pr_HighCE_lo"]
        d["Pr_HighState_hi95"] = d["Pr_HighCE_hi"]

    rows = []
    for ssrd in SSRD_ORDER:
        sub = d[d["SSRD_group"] == ssrd].copy()
        if len(sub) < 3:
            continue

        sort_col = "VPD_mid" if "VPD_mid" in sub.columns else "vpd_bin"
        sub = sub.sort_values(sort_col)

        first = sub.iloc[0]
        last = sub.iloc[-1]
        peak = sub.loc[sub["Pr_HighState_med"].idxmax()]

        p90_width = np.nan
        pr_width = np.nan
        if "metric_p90_lo95" in sub.columns and "metric_p90_hi95" in sub.columns:
            p90_width = np.nanmean(sub["metric_p90_hi95"] - sub["metric_p90_lo95"])
        if "Pr_HighState_lo95" in sub.columns and "Pr_HighState_hi95" in sub.columns:
            pr_width = np.nanmean(sub["Pr_HighState_hi95"] - sub["Pr_HighState_lo95"])

        rows.append({
            "method": method_label,
            "curve_type": curve_type,
            "SSRD_group": ssrd,
            "n_points": len(sub),
            "P90_change_last_minus_first": last["metric_p90_med"] - first["metric_p90_med"],
            "Pr_peak_minus_last": peak["Pr_HighState_med"] - last["Pr_HighState_med"],
            "Pr_peak": peak["Pr_HighState_med"],
            "Pr_last": last["Pr_HighState_med"],
            "Pr_peak_position": peak.get(sort_col, np.nan),
            "mean_P90_CI_width": p90_width,
            "mean_Pr_CI_width": pr_width,
            "min_n_cities": sub["n_cities"].min() if "n_cities" in sub.columns else np.nan,
            "median_n_cities": sub["n_cities"].median() if "n_cities" in sub.columns else np.nan
        })

    return pd.DataFrame(rows)

