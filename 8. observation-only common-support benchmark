        d = ce_summer.copy()
        d = d[np.isfinite(d[ce_col])].copy()

        base_d = d[d["Year"].isin(BASELINE_YEARS)].copy()

        thr = (
            base_d.groupby("city")[ce_col]
            .quantile(active_q)
            .rename("active_thr")
            .reset_index()
        )

        d = d.merge(thr, on="city", how="left")
        d["active_sens"] = (d[ce_col] > d["active_thr"]).astype(int)
        d["period"] = d["Year"].apply(classify_period)

        city_year = (
            d.groupby(["city", "Year"])
            .agg(Pactive=("active_sens", "mean"), n_obs=("active_sens", "size"))
            .reset_index()
        )

        city_year["period"] = city_year["Year"].apply(classify_period)

        city_period = (
            city_year[city_year["period"].isin(["early", "recent"])]
            .groupby(["city", "period"])
            .agg(Pactive=("Pactive", "mean"))
            .reset_index()
        )

        ci = bootstrap_paired_delta(city_period, "Pactive", BOOT_N, RANDOM_STATE)

        if ci is None:
            continue

        active_rows.append({
            "source": source,
            "active_q": active_q,
            **ci
        })

