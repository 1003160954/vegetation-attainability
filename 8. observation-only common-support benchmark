def savefig(fig, name):
    png = os.path.join(OUT_DIR, f"{name}.png")
    pdf = os.path.join(OUT_DIR, f"{name}.pdf")
    fig.savefig(png, dpi=DPI, bbox_inches="tight", facecolor="white")
    fig.savefig(pdf, dpi=DPI, bbox_inches="tight", facecolor="white")
    print("Saved:", png)
    print("Saved:", pdf)


def add_smooth(df, x_col, y_col, window=3):
    out = df.sort_values(x_col).copy()
    out[f"{y_col}_smooth"] = (
        out[y_col]
        .rolling(window=window, center=True, min_periods=1)
        .mean()
    )
    return out


def outside_legend(ax, title=None, anchor=(1.02, 0.5), loc="center left", fontsize=9):
    leg = ax.legend(
        frameon=False,
        title=title,
        bbox_to_anchor=anchor,
        loc=loc,
        fontsize=fontsize,
        borderaxespad=0.0
    )
    if leg and title:
        leg.get_title().set_fontsize(fontsize)
    return leg


