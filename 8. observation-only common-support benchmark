def add_bins(d):
    d = d.copy()

    d["T2M_bin"] = np.searchsorted(np.nanquantile(d["T2M_C"], [1/3, 2/3]), d["T2M_C"], side="right") + 1
    d["VPD_bin_bg"] = np.searchsorted(np.nanquantile(d["VPD_kPa"], [1/3, 2/3]), d["VPD_kPa"], side="right") + 1
    d["SSRD_bin_bg"] = np.searchsorted(np.nanquantile(d["SSRD_MJm2"], [1/3, 2/3]), d["SSRD_MJm2"], side="right") + 1

    if "SWVL1_m3m3" in d.columns:
        d["SM_bin"] = np.searchsorted(np.nanquantile(d["SWVL1_m3m3"], [1/3, 2/3]), d["SWVL1_m3m3"], side="right") + 1
    else:
        d["SM_bin"] = 2

    if "DEM" in d.columns:
        d["DEM_bin"] = np.searchsorted(np.nanquantile(d["DEM"], [1/3, 2/3]), d["DEM"], side="right") + 1
    else:
        d["DEM_bin"] = 2

    if "DIST_WATER_km" in d.columns:
        x = np.log1p(np.maximum(d["DIST_WATER_km"].to_numpy(float), 0))
        d["WATER_bin"] = np.searchsorted(np.nanquantile(x, [1/3, 2/3]), x, side="right") + 1
    else:
        d["WATER_bin"] = 2

    return d

