def savefig(fig, name):
    png = os.path.join(OUTDIR, f"{name}.png")
    pdf = os.path.join(OUTDIR, f"{name}.pdf")
    fig.savefig(png, dpi=DPI, bbox_inches="tight", facecolor="white")
    fig.savefig(pdf, bbox_inches="tight", facecolor="white")
    print("Saved:", png)


def city_tercile_labels(s):
    r = s.rank(method="average", pct=True)
    out = pd.Series(index=s.index, dtype="object")
    out[r <= 1/3] = "low"
    out[(r > 1/3) & (r <= 2/3)] = "mid"
    out[r > 2/3] = "high"
    return out


def global_vpd_bins(df, vpd_col, n_bins):
    x = df[vpd_col].to_numpy(float)
    x = x[np.isfinite(x)]
    cuts = np.nanquantile(x, np.linspace(0, 1, n_bins + 1)[1:-1])
    bins = np.searchsorted(cuts, df[vpd_col].to_numpy(float), side="right") + 1
    return bins, cuts


def bootstrap_city_median_curve(city_bin, metric_col, boot_n=500, seed=42):
    rng = np.random.default_rng(seed)
    cities = np.array(sorted(city_bin[CITY_COL].unique()))
    n_city = len(cities)
    rows = []

    keys = (
        city_bin[["SSRD_group", "vpd_bin"]]
        .drop_duplicates()
        .sort_values(["SSRD_group", "vpd_bin"])
    )

    for _, key in keys.iterrows():
        ssrd = key["SSRD_group"]
        vb = int(key["vpd_bin"])

        sub = city_bin[
            (city_bin["SSRD_group"] == ssrd) &
            (city_bin["vpd_bin"] == vb)
        ].copy()

        if sub[CITY_COL].nunique() < MIN_CITY_PER_BIN:
            continue

        vals_by_city = sub.set_index(CITY_COL)[metric_col].to_dict()
        vals = np.array([vals_by_city.get(c, np.nan) for c in cities], dtype=float)

        obs = np.nanmedian(vals)
        boots = np.empty(boot_n)

        for b in range(boot_n):
            idx = rng.integers(0, n_city, n_city)
            boots[b] = np.nanmedian(vals[idx])

        rows.append({
            "SSRD_group": ssrd,
            "vpd_bin": vb,
            "VPD_mid": sub["VPD_mid"].median(),
            f"{metric_col}_med": obs,
            f"{metric_col}_lo95": np.nanpercentile(boots, 2.5),
            f"{metric_col}_hi95": np.nanpercentile(boots, 97.5),
            "n_cities": sub[CITY_COL].nunique(),
            "n_obs": sub["n_obs"].sum(),
        })

    return pd.DataFrame(rows)


def combine_curves(p90_curve, pr_curve):
    return p90_curve.merge(
        pr_curve,
        on=["SSRD_group", "vpd_bin", "VPD_mid", "n_cities", "n_obs"],
        how="outer"
    )


def add_smooth(df, y_col, window=3):
    out = df.sort_values("VPD_mid").copy()
    out[f"{y_col}_smooth"] = (
        out[y_col]
        .rolling(window=window, center=True, min_periods=1)
        .mean()
    )
    return out


def shape_diagnostics(fig3_df, label):
    rows = []

    for ssrd in SSRD_ORDER:
        sub = fig3_df[fig3_df["SSRD_group"] == ssrd].sort_values("vpd_bin").copy()
        if len(sub) < 3:
            continue

        first = sub.iloc[0]
        last = sub.iloc[-1]
        peak = sub.loc[sub["Pr_HighState_med"].idxmax()]

        rows.append({
            "curve_type": label,
            "SSRD_group": ssrd,
            "n_points": len(sub),
            "VPD_first": first["VPD_mid"],
            "VPD_last": last["VPD_mid"],
            "P90_first": first["metric_p90_med"],
            "P90_last": last["metric_p90_med"],
            "P90_change_last_minus_first": last["metric_p90_med"] - first["metric_p90_med"],
            "Pr_first": first["Pr_HighState_med"],
            "Pr_last": last["Pr_HighState_med"],
            "Pr_peak": peak["Pr_HighState_med"],
            "Pr_peak_bin": int(peak["vpd_bin"]),
            "Pr_peak_VPD": peak["VPD_mid"],
            "Pr_peak_minus_last": peak["Pr_HighState_med"] - last["Pr_HighState_med"],
            "Pr_nonmonotonic_or_plateau": (
                peak["vpd_bin"] < last["vpd_bin"]
                and (peak["Pr_HighState_med"] - last["Pr_HighState_med"]) > 0.005
            ),
            "mean_P90_CI_width": np.nanmean(sub["metric_p90_hi95"] - sub["metric_p90_lo95"]),
            "mean_Pr_CI_width": np.nanmean(sub["Pr_HighState_hi95"] - sub["Pr_HighState_lo95"]),
            "min_n_cities": sub["n_cities"].min(),
            "median_n_cities": sub["n_cities"].median(),
        })

    return pd.DataFrame(rows)

