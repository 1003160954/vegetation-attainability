def add_highce_state(data, high_q):
    d = data.copy()
    thr = (
        d.groupby(CITY_COL)[CE_COL]
        .quantile(high_q)
        .rename("highce_thr")
        .reset_index()
    )
    d = d.merge(thr, on=CITY_COL, how="left")
    d["Emp_HighCE_final"] = (d[CE_COL] >= d["highce_thr"]).astype(int)
    return d


def compute_moisture_balanced_fig3(data, high_col):
    # City × SSRD × VPD × SM
    city_sm_bin = (
        data.groupby([CITY_COL, "SSRD_group", "vpd_bin", "SM_group"])
        .agg(
            VPD_mid=(VPD_COL, "median"),
            metric_p90=(CE_COL, lambda x: np.nanquantile(x, 0.90)),
            Pr_HighState=(high_col, "mean"),
            n_obs=(high_col, "size"),
            SM_median=(SM_COL, "median")
        )
        .reset_index()
    )

    city_sm_bin = city_sm_bin[city_sm_bin["n_obs"] >= MIN_OBS_PER_CITY_SM_BIN].copy()

    sm_support = (
        city_sm_bin.groupby([CITY_COL, "SSRD_group", "vpd_bin"])
        .agg(
            n_sm_strata=("SM_group", "nunique"),
            total_obs=("n_obs", "sum")
        )
        .reset_index()
    )

    city_sm_bin = city_sm_bin.merge(
        sm_support,
        on=[CITY_COL, "SSRD_group", "vpd_bin"],
        how="left"
    )

    city_sm_bin = city_sm_bin[
        city_sm_bin["n_sm_strata"] >= MIN_SM_STRATA_PER_CITY_BIN
    ].copy()

    # Equal-weight soil moisture strata inside each city × SSRD × VPD bin
    balanced_city_bin = (
        city_sm_bin.groupby([CITY_COL, "SSRD_group", "vpd_bin"])
        .agg(
            VPD_mid=("VPD_mid", "median"),
            metric_p90=("metric_p90", "mean"),
            Pr_HighState=("Pr_HighState", "mean"),
            n_obs=("total_obs", "max"),
            n_sm_strata=("n_sm_strata", "max"),
            SM_median=("SM_median", "median")
        )
        .reset_index()
    )

    balanced_city_bin = balanced_city_bin[
        balanced_city_bin["n_obs"] >= MIN_OBS_PER_CITY_BIN
    ].copy()

    p90_curve = bootstrap_city_median_curve(
        balanced_city_bin,
        "metric_p90",
        BOOT_N,
        RANDOM_STATE + 10
    )

    pr_curve = bootstrap_city_median_curve(
        balanced_city_bin,
        "Pr_HighState",
        BOOT_N,
        RANDOM_STATE + 11
    )

    fig3 = combine_fig3(p90_curve, pr_curve)

    return city_sm_bin, balanced_city_bin, fig3


def compute_fig5_divergence(data, high_col):
    city_avg = (
        data[data["period"].isin(["early", "recent"])]
        .groupby([CITY_COL, "period"])
        .agg(PrHigh_avg=(high_col, "mean"))
        .reset_index()
    )

    city_ext = (
        data[
            (data["demand_group"] == "high") &
            (data["period"].isin(["early", "recent"]))
        ]
        .groupby([CITY_COL, "period"])
        .agg(PrHigh_extreme=(high_col, "mean"))
        .reset_index()
    )

    cd = city_avg.merge(city_ext, on=[CITY_COL, "period"], how="outer")

    wide = cd.pivot(index=CITY_COL, columns="period")
    wide.columns = [f"{a}_{b}" for a, b in wide.columns]
    wide = wide.reset_index()

    needed = [
        "PrHigh_avg_early", "PrHigh_avg_recent",
        "PrHigh_extreme_early", "PrHigh_extreme_recent"
    ]

    for c in needed:
        if c not in wide.columns:
            wide[c] = np.nan

    wide["d_avg"] = wide["PrHigh_avg_recent"] - wide["PrHigh_avg_early"]
    wide["d_extreme"] = wide["PrHigh_extreme_recent"] - wide["PrHigh_extreme_early"]
    wide["div_type"] = [
        classify_quad(x, y)
        for x, y in zip(wide["d_avg"], wide["d_extreme"])
    ]

    valid = wide.dropna(subset=["d_avg", "d_extreme"]).copy()

    if len(valid) > 5:
        r, p = spearmanr(valid["d_avg"], valid["d_extreme"])
    else:
        r, p = np.nan, np.nan

    counts = valid["div_type"].value_counts()

    summary = pd.DataFrame([{
        "n_cities": len(valid),
        "spearman_r": r,
        "spearman_p": p,
        "gain_both": int(counts.get("gain_both", 0)),
        "gain_avg_lose_extreme": int(counts.get("gain_avg_lose_extreme", 0)),
        "lose_both": int(counts.get("lose_both", 0)),
        "lose_avg_gain_extreme": int(counts.get("lose_avg_gain_extreme", 0)),
    }])

    return valid, summary


