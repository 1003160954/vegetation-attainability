def existing_path(paths):
    for p in paths:
        if os.path.exists(p):
            return p
    raise FileNotFoundError("No existing file found:\n" + "\n".join(paths))


def pick_col(df, candidates, required=True):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise ValueError(f"Cannot find any of {candidates}\nAvailable columns:\n{df.columns.tolist()}")
    return None


def savefig(fig, name):
    png = os.path.join(OUTDIR, f"{name}.png")
    pdf = os.path.join(OUTDIR, f"{name}.pdf")
    fig.savefig(png, dpi=DPI, bbox_inches="tight", facecolor="white")
    fig.savefig(pdf, bbox_inches="tight", facecolor="white")
    print("Saved:", png)


def classify_period(y):
    if y in BASELINE_YEARS:
        return "early"
    if y in RECENT_YEARS:
        return "recent"
    return "middle"


def topk_months_by_baseline_t2m(g, month_col, t2m_col, k=3):
    m = g.groupby(month_col)[t2m_col].mean().sort_values(ascending=False)
    return sorted(m.index.astype(int).tolist()[:k])


def city_tercile_labels(s):
    r = s.rank(method="average", pct=True)
    out = pd.Series(index=s.index, dtype="object")
    out[r <= 1/3] = "low"
    out[(r > 1/3) & (r <= 2/3)] = "mid"
    out[r > 2/3] = "high"
    return out


def city_percentile_bins(s, n_bins=12):
    r = s.rank(method="average", pct=True)
    b = np.ceil(r * n_bins).astype(int)
    b = np.clip(b, 1, n_bins)
    return b


def classify_quad(x, y):
    if not np.isfinite(x) or not np.isfinite(y):
        return "missing"
    if x >= 0 and y >= 0:
        return "gain_both"
    if x >= 0 and y < 0:
        return "gain_avg_lose_extreme"
    if x < 0 and y < 0:
        return "lose_both"
    return "lose_avg_gain_extreme"


def bootstrap_paired_delta(city_period, value_col, boot_n=500, seed=42):
    wide = city_period.pivot(index="city", columns="period", values=value_col)
    wide = wide.dropna(subset=["early", "recent"]).copy()

    if len(wide) == 0:
        return None

    e = wide["early"].to_numpy(float)
    r = wide["recent"].to_numpy(float)
    d = r - e
    n = len(wide)

    rng = np.random.default_rng(seed)
    boot_e = np.empty(boot_n)
    boot_r = np.empty(boot_n)
    boot_d = np.empty(boot_n)

    for b in range(boot_n):
        idx = rng.integers(0, n, n)
        boot_e[b] = np.nanmean(e[idx])
        boot_r[b] = np.nanmean(r[idx])
        boot_d[b] = np.nanmean(d[idx])

    try:
        _, p_w = wilcoxon(r, e)
    except Exception:
        p_w = np.nan

    return {
        "n_cities": int(n),
        "early_mean": float(np.nanmean(e)),
        "early_lo95": float(np.nanpercentile(boot_e, 2.5)),
        "early_hi95": float(np.nanpercentile(boot_e, 97.5)),
        "recent_mean": float(np.nanmean(r)),
        "recent_lo95": float(np.nanpercentile(boot_r, 2.5)),
        "recent_hi95": float(np.nanpercentile(boot_r, 97.5)),
        "delta_mean": float(np.nanmean(d)),
        "delta_lo95": float(np.nanpercentile(boot_d, 2.5)),
        "delta_hi95": float(np.nanpercentile(boot_d, 97.5)),
        "n_increase": int(np.sum(d > 0)),
        "wilcoxon_p": float(p_w) if np.isfinite(p_w) else np.nan,
    }


def bootstrap_fig3_city_median(city_bin, metric_col, boot_n=500, seed=42):
    rng = np.random.default_rng(seed)
    rows = []

    cities = np.array(sorted(city_bin["city"].unique()))
    n_city = len(cities)

    keys = city_bin[["SSRD_group", "vpd_bin"]].drop_duplicates()
    keys = keys.sort_values(["SSRD_group", "vpd_bin"])

    for _, key in keys.iterrows():
        ssrd = key["SSRD_group"]
        vb = key["vpd_bin"]

        sub = city_bin[(city_bin["SSRD_group"] == ssrd) & (city_bin["vpd_bin"] == vb)]

        if sub["city"].nunique() < MIN_CITY_PER_BIN:
            continue

        vals_by_city = sub.set_index("city")[metric_col].to_dict()
        vals = np.array([vals_by_city.get(c, np.nan) for c in cities], dtype=float)

        obs = np.nanmedian(vals)
        boots = np.empty(boot_n)

        for b in range(boot_n):
            idx = rng.integers(0, n_city, n_city)
            boots[b] = np.nanmedian(vals[idx])

        rows.append({
            "SSRD_group": ssrd,
            "vpd_bin": int(vb),
            "VPD_mid": sub["VPD_mid"].median(),
            f"{metric_col}_med": obs,
            f"{metric_col}_lo95": np.nanpercentile(boots, 2.5),
            f"{metric_col}_hi95": np.nanpercentile(boots, 97.5),
            "n_cities": sub["city"].nunique(),
            "n_obs": sub["n_obs"].sum(),
        })

    return pd.DataFrame(rows)


def compute_fig3_city_bin(df, metric_col, high_state_col):
    d = df.copy()
    d["SSRD_group"] = d.groupby("city")["SSRD_MJm2"].transform(city_tercile_labels)
    d["vpd_bin"] = d.groupby("city")["VPD_kPa"].transform(lambda s: city_percentile_bins(s, N_VPD_BINS))

    city_bin = (
        d.groupby(["city", "SSRD_group", "vpd_bin"])
        .agg(
            VPD_mid=("VPD_kPa", "median"),
            metric_p90=(metric_col, lambda x: np.nanquantile(x, 0.90)),
            Pr_HighState=(high_state_col, "mean"),
            n_obs=(high_state_col, "size"),
        )
        .reset_index()
    )

    city_bin = city_bin[city_bin["n_obs"] >= MIN_OBS_PER_CITY_BIN].copy()
    return city_bin


def aggregate_fig3_no_boot(city_bin):
    g = (
        city_bin.groupby(["SSRD_group", "vpd_bin"])
        .agg(
            VPD_mid=("VPD_mid", "median"),
            metric_p90_med=("metric_p90", "median"),
            metric_p90_lo=("metric_p90", lambda x: np.nanquantile(x, 0.25)),
            metric_p90_hi=("metric_p90", lambda x: np.nanquantile(x, 0.75)),
            Pr_HighState_med=("Pr_HighState", "median"),
            Pr_HighState_lo=("Pr_HighState", lambda x: np.nanquantile(x, 0.25)),
            Pr_HighState_hi=("Pr_HighState", lambda x: np.nanquantile(x, 0.75)),
            n_cities=("city", "nunique"),
            n_obs=("n_obs", "sum"),
        )
        .reset_index()
    )
    return g[g["n_cities"] >= MIN_CITY_PER_BIN].copy()


