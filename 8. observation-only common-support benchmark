    raise FileNotFoundError("No empirical CE file found:\n" + "\n".join(paths))


def pick_col(df, candidates, required=True):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise ValueError(f"Cannot find any of {candidates}\nAvailable columns:\n{df.columns.tolist()}")
    return None


