BASE1 = "/content/drive/MyDrive/Second_research/MERRA/hybrid/post_fig4_logic_closure_v2"
BASE2 = "/content/drive/MyDrive/Second_research/MERRA/hybrid/post_fig4_patchlevel_citypix"
BASE3 = "/content/drive/MyDrive/Second_research/MERRA/hybrid/post_fig4_peak_position_summer_highE"
