def bootstrap_ci_mean(x, n_boot=1000, seed=42):
    rng = np.random.default_rng(seed)
    x = np.asarray(x, dtype=float)
    x = x[np.isfinite(x)]
    if len(x) == 0:
        return np.nan, np.nan, np.nan
    boots = []
    for _ in range(n_boot):
        s = rng.choice(x, size=len(x), replace=True)
        boots.append(np.mean(s))
    return np.mean(x), np.percentile(boots, 2.5), np.percentile(boots, 97.5)

def add_panel_label(ax, label):
    ax.text(-0.12, 1.04, label, transform=ax.transAxes,
            fontsize=10, fontweight="bold", va="bottom", ha="left")

def strip_top_right(ax):
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

