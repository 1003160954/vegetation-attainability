#    cooling_efficiency = cooling_strength / (EVI - 0.05), only when dEVI >= 0.02
# ============================================================

EVI_BASELINE = 0.05
MIN_DEVI = 0.02

def compute_ce_for_source(df_in, X_full, source_name,
                          evi_baseline=0.05,
                          min_devi=0.02,
                          add_shared_cols=False):
    """
    source_name = 'ERA5' or 'MERRA2'

    Returns:
      - source-specific prediction columns
      - optionally shared cols:
          dEVI_ref
          EVI_baseline_used

    Note:
      shared cols should only be added ONCE to avoid duplicate names
      when concatenating ERA5 and MERRA2 outputs.
    """
    X_obs = X_full.copy()
    X_cf  = X_full.copy()

    if "EVI" not in X_cf.columns:
        raise ValueError("❌ EVI must be included in feature_cols for counterfactual prediction.")

    # revised counterfactual baseline
    X_cf["EVI"] = evi_baseline

    pred_obs = predict_model(final, X_obs)
    pred_cf  = predict_model(final, X_cf)

    out = pd.DataFrame(index=df_in.index)

    # keep old column naming for minimal downstream changes
    out[f"LST_pred_{source_name}"] = np.asarray(pred_obs, dtype=float)
    out[f"LST_pred_noEVI_{source_name}"] = np.asarray(pred_cf, dtype=float)
    out[f"cooling_strength_pred_{source_name}"] = (
        out[f"LST_pred_noEVI_{source_name}"].to_numpy(dtype=float)
        - out[f"LST_pred_{source_name}"].to_numpy(dtype=float)
    )

    # revised denominator
    dEVI = df_in["EVI"].to_numpy(dtype=float) - float(evi_baseline)

    ce = np.where(
        dEVI >= float(min_devi),
        out[f"cooling_strength_pred_{source_name}"].to_numpy(dtype=float) / dEVI,
        np.nan
    )
    out[f"cooling_efficiency_{source_name}"] = ce

    # IMPORTANT: shared cols only once
    if add_shared_cols:
        out["dEVI_ref"] = dEVI
        out["EVI_baseline_used"] = float(evi_baseline)

    return out

