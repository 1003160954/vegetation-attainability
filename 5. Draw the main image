def predict_model(model, X: pd.DataFrame) -> np.ndarray:
    """
    Supports common sklearn / xgboost / catboost APIs.
    """
    # xgboost sklearn API / sklearn API
    if hasattr(model, "predict"):
        try:
            y = model.predict(X)
            return np.asarray(y, dtype=float)
        except Exception:
            pass

        try:
            y = model.predict(X.to_numpy(dtype=float))
            return np.asarray(y, dtype=float)
        except Exception:
            pass

    # xgboost Booster
    try:
        import xgboost as xgb
        if isinstance(model, xgb.Booster):
            dmat = xgb.DMatrix(X)
            y = model.predict(dmat)
            return np.asarray(y, dtype=float)
    except Exception:
        pass

    raise ValueError("❌ Unsupported model type or prediction failed.")

