    base = df[(df["year"] >= BASELINE_Y0) & (df["year"] <= BASELINE_Y1)].copy()

    mm = (
        base.groupby([COL_CITY, "month"], as_index=False)[COL_T2M]
            .mean()
            .sort_values([COL_CITY, COL_T2M], ascending=[True, False])
    )
    mm["rk"] = mm.groupby(COL_CITY).cumcount() + 1
    hot = mm[mm["rk"] <= HOTTEST_N_MONTHS][[COL_CITY, "month"]].copy()
    hot["is_summer"] = 1

    out = df.merge(hot, on=[COL_CITY, "month"], how="left")
    out["is_summer"] = out["is_summer"].fillna(0).astype(int)
    return out[out["is_summer"] == 1].copy()

def add_highce_flag(df_s):
    thr = (
        df_s.groupby(COL_CITY)[TARGET_CE]
            .quantile(HIGH_Q_CITY)
            .rename("thr_highce")
            .reset_index()
    )
    out = df_s.merge(thr, on=COL_CITY, how="left")
    out["HighCE"] = (out[TARGET_CE] >= out["thr_highce"]).astype(int)
    return out

def add_ssrd_group(df_s):
    q1, q2 = df_s[COL_SSRD].quantile([1/3, 2/3]).to_list()

    def lab(v):
        if v <= q1:
            return "low"
        elif v <= q2:
            return "mid"
        else:
            return "high"

    out = df_s.copy()
    out["SSRD_group"] = out[COL_SSRD].map(lab)
    return out

def summarize_window_metrics_groupwise_vpd(df_s):
    """
    Critical fix:
    qcut VPD separately WITHIN each SSRD group
    """
    rows = []

    for g, sub in df_s.groupby("SSRD_group"):
        sub = sub.copy()
        sub["vpd_bin"] = pd.qcut(sub[COL_VPD], q=VPD_BINS, duplicates="drop")

        tmp = (
            sub.groupby("vpd_bin", observed=True)
               .agg(
                   CE_p90=(TARGET_CE, lambda x: float(np.quantile(x, CE_Q))),
                   Pr_HighCE=("HighCE", "mean"),
                   n=(TARGET_CE, "size"),
                   VPD_mid=(COL_VPD, "median")
               )
               .reset_index()
               .sort_values("VPD_mid")
        )
        tmp["SSRD_group"] = g
        tmp["bin_id"] = np.arange(len(tmp))
        rows.append(tmp)

    out = pd.concat(rows, axis=0, ignore_index=True)
    return out

def run_fig3_core(df_in, source_name):
    d = df_in.copy()
    d = d.replace([np.inf, -np.inf], np.nan).dropna(subset=[COL_CITY, COL_DATE, TARGET_CE, COL_T2M, COL_VPD, COL_SSRD]).copy()

    d_s = define_city_summer(d)
    d_s = add_highce_flag(d_s)
    d_s = add_ssrd_group(d_s)
    out = summarize_window_metrics_groupwise_vpd(d_s)
    out["source"] = source_name

    print(f"{source_name}: summer rows = {len(d_s):,}, cities = {d_s[COL_CITY].nunique()}, output rows = {len(out)}")
    print(out.groupby("SSRD_group").size())

    return out, d_s

