def winsorize_series(s, q=(0.2, 99.8)):
    x = pd.to_numeric(s, errors="coerce").to_numpy(dtype=float)
    ok = np.isfinite(x)
    if ok.sum() < 10:
        return s
    lo, hi = np.nanpercentile(x[ok], q)
    return pd.Series(np.clip(x, lo, hi), index=s.index)

